{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "statusLine": {
    "type": "command",
    "command": "ccline",
    "padding": 0
  },
  "enabledPlugins": {
    "jira-assistant@mdb": true,
    "gitlab-assistant@mdb": true,
    "ista-presentation@ista-marketplace": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "mdb": {
      "source": {
        "source": "git",
        "url": "git@gitlab.com:ista-se/cas/dsp-mdb/ai-tooling/marketplace.git"
      }
    },
    "ista-marketplace": {
      "source": {
        "source": "git",
        "url": "git@gitlab.com:ista-se/cas/dsp/ai-dev-tools/marketplace.git"
      }
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/git/gbastkowski/mcp-atuin/hooks/claude-atuin-record.sh"
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": false,
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "voiceEnabled": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754085994342
  }
