{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "CLAUDE.md",
    "CONTRIBUTING.md",
    "docs/guidelines.md"
  ],
  "plugin": [
    "opencode-websearch-cited@1.1.1",
    "@zenobius/opencode-skillful",
    "opencode-openai-codex-auth",
    "oh-my-opencode@latest"
  ],
  "tools": {
    "bash": true,
    "glob": true,
    "grep": true,
    "list": true,
    "patch": true,
    "skill": true,
    "todoread": true,
    "todowrite": true,
    "webfetch": true,
    "write": true
  },
  "formatter": {
    "scalafmt": {
      "command": [
        "scalafmt",
        "$FILE"
      ],
      "extensions": [
        ".scala",
        ".sc",
        ".sbt"
      ]
    }
  },
  "mcp": {
    "agentvibes": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "--package=agentvibes",
        "agentvibes-mcp-server"
      ]
    },
    "emacs": {
      "type": "local",
      "enabled": true,
      "command": [
        "node",
        "/home/gunnar/git/gbastkowski/mcp-emacs/bin/mcp-emacs.js",
        "--emacsclient-executable",
        "/usr/bin/emacsclient"
      ]
    }
  },
  "provider": {
    "openai": {
      "options": {
        "reasoningEffort": "medium",
        "reasoningSummary": "auto",
        "textVerbosity": "medium",
        "include": [
          "reasoning.encrypted_content"
        ],
        "store": false,
        "websearch_cited": {
          "model": "gpt-5.1"
        }
      },
      "models": {
        "gpt-5.2": {
          "name": "GPT 5.2 (OAuth)",
          "limit": {
            "context": 272000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "none": {
              "reasoningEffort": "none",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            }
          }
        },
        "gpt-5.2-codex": {
          "name": "GPT 5.2 Codex (OAuth)",
          "limit": {
