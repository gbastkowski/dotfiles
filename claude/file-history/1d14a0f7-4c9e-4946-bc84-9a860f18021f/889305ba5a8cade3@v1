  /**
   * This implementation runs a query against all readings.
   * The right implementation would run a query against the device status table filled by collector, however
   * the latest device status will not be available for up to 1 year after migration until first real readings
   * are received.
   *
   * This is why this method keeps two implementations.
   * TODO: Think about how we could switch to newer status earlier, e.g. with a DB job during migration.
   */
  private val GET_DEVICE_READINGS_STATUS_FAKED = true

  // todo langerca 2 if RdssDeviceStatusResponse contains Map[DeviceId,RdssDeviceStatus], which would be a better
  // match to the domain semantic, this method needs to adapt
  override def getDeviceReadingsStatus(request: RdssDeviceStatusRequest): Try[RdssDeviceStatusResponse] = Try {
    def incomplete(device: DeviceId) = RdssDeviceStatus(device, RdssDeviceReadingsCompleteness.INCOMPLETE)

    def complete(device: DeviceId) = RdssDeviceStatus(device, RdssDeviceReadingsCompleteness.COMPLETE)

    def isDeadlineDevice(an: ArticleNr, ran: Option[ArticleNr]): Boolean = {
      def toServiceAN(an: ArticleNr): ArticleServiceAN = ArticleServiceAN(an.value)

      // device is a deadline device if the radio article is a deadline device or if the main article is one
      val ranIsDlD = ran.flatMap(n => deadlineDeviceCheck.isDeadlineDevice(toServiceAN(n))).contains(true)
      val anIsDlD = deadlineDeviceCheck.isDeadlineDevice(toServiceAN(an)).contains(true)
      ranIsDlD || anIsDlD
    }

    if (request.periodEndDate.getZone != request.periodStartDate.getZone)
      throw new MdrInvalidParametersException("Only timespans with the same ZoneId in from and to are allowed.")

    if (GET_DEVICE_READINGS_STATUS_FAKED) {
      val readings = meterDataRepository.existReadingsByMainDevice(
        request.deviceIds,
        LocalTimespan(request.periodStartDate, request.periodEndDate),
        Set(MdrReadingType.Current, MdrReadingType.Deadline)
      )
      val byDevice = readings.groupBy(_.deviceId)
      val statuus: Iterable[RdssDeviceStatus] = request.deviceIds.map { device =>
        byDevice.get(device).map { readingsInfos =>
          // there are readings infos - check whether there is a deadline reading
          if (readingsInfos.exists(_.readingType == MdrReadingType.Deadline)) {
            // there is a deadline reading in the timeframe - done
            complete(device)
          } else {
            readingsInfos.find(_.readingType == MdrReadingType.Current).map { r =>
              // there is a current reading - only allowed for non-deadline devices
              if (isDeadlineDevice(r.mainArticle, r.lastRadioArticle))
                incomplete(device)
              else
                complete(device)
            }.getOrElse(incomplete(device))
          }
        }.getOrElse(incomplete(device))
      }
      RdssDeviceStatusResponse(statuus)
    } else {
      //noinspection NotImplementedCode
      ??? // TODO Implement query against new device status table
    }
  }

