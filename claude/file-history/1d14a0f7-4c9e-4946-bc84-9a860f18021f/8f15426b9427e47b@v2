    "update data retention for all meter ports in the same property" in {
      for {
        _ <- mdr.truncateReadings()
        _ <- mdr.truncateMeterPortsTable()
        _ <- mdr.upsertMeterPorts(meterPortConfigs1)
        _ <- mdr.upsertMeterPorts(meterPortConfigs2)
        p1 = mdr.findMeterPortsByProperty(None, property1)
        p2 = mdr.findMeterPortsByProperty(None, property2)
        _ <- mdr.updatePropertyDataRetention(property1, CompoundRetentionPolicy.MONTH_END_VALUES_DEFAULT)
        p3 = mdr.findMeterPortsByProperty(None, property1)
        p4 = mdr.findMeterPortsByProperty(None, property2)
        _ <- mdr.updatePropertyDataRetention(property2, CompoundRetentionPolicy.MONTH_MID_5_YEARS_OTHER_DEFAULT)
        p5 = mdr.findMeterPortsByProperty(None, property1)
        p6 = mdr.findMeterPortsByProperty(None, property2)
      } yield {
        p1 should have size 5
        super[PostgresSpec].forAll(p1) { p => p.retentionPolicy shouldBe CompoundRetentionPolicy.DEFAULT }

        p2 should have size 5
        p2.find(_.serialNr == SerialNr("101")).get.retentionPolicy shouldBe CompoundRetentionPolicy.MONTH_END_VALUES_DEFAULT
        p2.find(_.serialNr == SerialNr("102")).get.retentionPolicy shouldBe CompoundRetentionPolicy.MONTH_MID_5_YEARS_OTHER_DEFAULT
        p2.find(_.serialNr == SerialNr("103")).get.retentionPolicy shouldBe CompoundRetentionPolicy.NO_DAILY_VALUES_OTHER_DEFAULT
        p2.find(_.serialNr == SerialNr("104")).get.retentionPolicy shouldBe CompoundRetentionPolicy.DAILY_VALUES_5_YEARS_OTHER_DEFAULT
        p2.find(_.serialNr == SerialNr("105")).get.retentionPolicy shouldBe CompoundRetentionPolicy.DEFAULT

        p3 should have size 5
        super[PostgresSpec].forAll(p3) { p => p.retentionPolicy shouldBe CompoundRetentionPolicy.MONTH_END_VALUES_DEFAULT }

        p4 should have size 5
        p4.find(_.serialNr == SerialNr("101")).get.retentionPolicy shouldBe CompoundRetentionPolicy.MONTH_END_VALUES_DEFAULT
        p4.find(_.serialNr == SerialNr("102")).get.retentionPolicy shouldBe CompoundRetentionPolicy.MONTH_MID_5_YEARS_OTHER_DEFAULT
        p4.find(_.serialNr == SerialNr("103")).get.retentionPolicy shouldBe CompoundRetentionPolicy.NO_DAILY_VALUES_OTHER_DEFAULT
        p4.find(_.serialNr == SerialNr("104")).get.retentionPolicy shouldBe CompoundRetentionPolicy.DAILY_VALUES_5_YEARS_OTHER_DEFAULT
        p4.find(_.serialNr == SerialNr("105")).get.retentionPolicy shouldBe CompoundRetentionPolicy.DEFAULT

        p5 should have size 5
        super[PostgresSpec].forAll(p5) { p => p.retentionPolicy shouldBe CompoundRetentionPolicy.MONTH_END_VALUES_DEFAULT }

        p6 should have size 5
        super[PostgresSpec].forAll(p6) { p => p.retentionPolicy shouldBe CompoundRetentionPolicy.MONTH_MID_5_YEARS_OTHER_DEFAULT }
      }
