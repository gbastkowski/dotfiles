  // todo change these tests if the domain code is changed to better handle inconsistent readings
  // See comment above for testing mapToRdasMeterPorts why we test mainly mapToMeterPortIDRdasMeterPortMap.
  // The following tests are a bit complicated because of a domain logic inconsistency.
  // In EmitterMdrRgcServiceImpl.MdrRdasMappings.mapToMeterPortIDRdasMeterPortMap the RdasMeterPorts are built
  // by first grouping per meter port, and then per group mostly by copying reference values from one reading into
  // other readings.
  // For locationId, port, mainDeviceId, mainArticleNr, mainSerialNr and measurand this is ok,
  // as all of them come from the meterports table of the meter port used for the grouping.
  // However, radioArticleNr, radioSerialNr and unit are overwritten by the values from a reference
  // reading although they come from the readings table and thus - in theory - could be different for
  // different readings.
  // See also the comment at EmitterMdrRgcServiceImpl.MdrRdasMappings.mapToMeterPortIDRdasMeterPortMap.
  // We know that during migration the situation can happen that different readings have different values for
  // the fields which in the resulting RdasMeterPort are collapsed to a single value.
  // Consequently these tests use generated values where indeed the values which are copied from a reference reading
  // will differ between different readings.
  // Thus the tests are designed to only be able to state what remains true if original values
  // are replaced by different reference values.
  "EmitterMdrRgcServiceImpl.MdrRdasMappings.mapToMeterPortIDRdasMeterPortMap" should {

    trait SUT extends BaseSUT {
      lazy val stubCalibrationCheck: CalibrationCheck = calibrationCheckStub(None)
    }

    "group mdrMeterReadings by meterPortId - check number of groups and size per group is correct" in new SUT {
      forAll(genMdrMeterReadingsAnyTimeZone) { mdrMeterReadings =>
        val mdrMeterReadingGroupsSizes = mdrMeterReadings
          .groupBy(groupingKey)
          .view.mapValues(_.size)
          // .toMap is needed as shouldEqual for MapView falls back to == which is not defined on MapView and thus falls
          // back to the default to compare object references instead of content.
          .toMap

        val meterPortIDRdasMeterPortMap = mapToMeterPortIdRdasMeterPortMap(stubCalibrationCheck)(mdrMeterReadings)
        val rdasMeterPortReadingsSizes = meterPortIDRdasMeterPortMap.view.mapValues(_.readings.size).toMap
        rdasMeterPortReadingsSizes shouldEqual mdrMeterReadingGroupsSizes
      }
    }

    // Check that for each RdasMeterPort there exists inside the corresponding group of MdrMeterReading
    // at least one MdrMeterReading which is the reference to this RdasMeterPort,
    // i.e. all but radioComponentId and readings match.
    "group mdrMeterReadings by meterPortId - check reference value exists per group" in new SUT {
      private def isReference(rdasMeterPort: RdasMeterPort)(mdrMeterReading: MdrMeterReading): Boolean =
        rdasMeterPort.locationId == mdrMeterReading.locationId.value &&
        rdasMeterPort.port == mdrMeterReading.port &&
        rdasMeterPort.mainDeviceId == mdrMeterReading.mainDeviceId.value &&
        rdasMeterPort.mainArticleNr == mdrMeterReading.mainArticleNr.value &&
        rdasMeterPort.mainSerialNr == mdrMeterReading.mainSerialNr.value &&
        rdasMeterPort.radioArticleNr == mdrMeterReading.radioArticleNr.map(_.value) &&
        rdasMeterPort.radioSerialNr == mdrMeterReading.radioSerialNr.map(_.value) &&
        rdasMeterPort.measurand == mdrMeterReading.measurand.entryName

      forAll(genMdrMeterReadingsAnyTimeZone) { mdrMeterReadings =>
        val meterPortIdMdrMeterReadingsMap = mdrMeterReadings.groupBy(groupingKey)

        val meterPortIdRdasMeterPortMap = mapToMeterPortIdRdasMeterPortMap(stubCalibrationCheck)(mdrMeterReadings)

