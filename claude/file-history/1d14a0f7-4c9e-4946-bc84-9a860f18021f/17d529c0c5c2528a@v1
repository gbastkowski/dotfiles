  ////////////////////////VALIDATION FUNCTIONS///////////////////////////////

  //Allow multiple validation for the tag input field
  private def validateNumberField(maxLength: Int): String => (Boolean, String) = input =>
    if (!validateDigitsNumber(input)) (false, t("ReadingsSearchLoc.Notifications.OnlyDigits"))
    else if (input.length > maxLength) (false, t("ReadingsSearchLoc.Notifications.MaxLength", maxLength.toString))
    else (true, "")

  private def validateDigitsNumber(input: String): Boolean = {
    val pattern = Pattern.compile("^[0-9]*$")
    input.isEmpty || pattern.matcher(input).matches()
  }

  private def validatePropertyNumberField(input: String): Option[String] = {
    import ReadingsSearchPropertyConverter._

    val maybeErrors = toValueSet(input)
      .map { x =>
        if (isUuidWithOptionalHyphen(x)) {
          sanitizePropertyId(x).fold(e => Option(t("ReadingsSearchLoc.Notifications.InvalidPropertyNumberFormat")), _ => Option.empty)
        } else if (isValidPropertyNumber(x)) {
          val sanitized = sanitizePropertyNumber(x)
          val checkDigit = ReadingsSearchPropertyConverter.checkDigit(sanitized.take(9))
          if ((sanitized.length == 10 && checkDigit == sanitized.takeRight(1)) || sanitized.length == 9) Option.empty
          else Option(t("ReadingsSearchLoc.Notifications.InvalidPropertyNumberCheckDigit"))
        } else {
          Option(t("ReadingsSearchLoc.Notifications.InvalidPropertyNumberFormat"))
        }
      }

    maybeErrors.find(_.nonEmpty).flatten
  }
  ////////////////////////END VALIDATION FUNCTIONS///////////////////////////////

