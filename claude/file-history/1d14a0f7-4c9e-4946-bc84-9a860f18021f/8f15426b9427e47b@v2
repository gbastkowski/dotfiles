    "overwrite existing readings only if overwrite is requested" in {
      val readingsCount = 10
      val intervalSeconds = 60
      val valueStep = 0.1

      val readings1 = meterPortConfigs1.flatMap(mp => createReadings(mp, readingsCount, instDate1, intervalSeconds, valueStep))
      val readings2 = readings1.map(r => r.copy(value = r.value + 1.0))

      val timespan = LocalTimespan(instDate1, instDate1.plusSeconds((intervalSeconds * readingsCount) + 1))

      for {
        _ <- mdr.truncateReadings()
        _ <- mdr.truncateMeterPortsTable()
        _ <- mdr.upsertMeterPorts(meterPortConfigs1)
        _ = mdr.insertReadings(readings1, overwrite = false)
        retrieved1 <- Future.traverse(meterPortConfigs1) { mp =>
          mdr.findReadingsByMeterPort(mp.execPlanId, mp.mainDeviceId, mp.portNr, timespan)
        }
        _ = mdr.insertReadings(readings2, overwrite = false)
        retrieved2 <- Future.traverse(meterPortConfigs1) { mp =>
          mdr.findReadingsByMeterPort(mp.execPlanId, mp.mainDeviceId, mp.portNr, timespan)
        }
        _ = mdr.insertReadings(readings2)
        retrieved3 <- Future.traverse(meterPortConfigs1) { mp =>
          mdr.findReadingsByMeterPort(mp.execPlanId, mp.mainDeviceId, mp.portNr, timespan)
