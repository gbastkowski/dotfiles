        MdrMediumType.values.map(m => baseReading.copy(mediumType = m, consumptionDate = nextReadingTime, value = nextReadingValue)) ++
        MdrEstimationType.values.map(e => baseReading.copy(estimationType = e, consumptionDate = nextReadingTime, value = nextReadingValue, migrated = true))

      logger.info(s"Combinations of reading attributes: ${readings.size}. Readings timespan: $startTime - $lastReadingTime values: $startValue - $lastValue")

