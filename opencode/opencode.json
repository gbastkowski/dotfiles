{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/qwen-coder",
  "small_model": "ollama/qwen-coder",
  "instructions": [
    "CLAUDE.md",
    "CONTRIBUTING.md",
    "docs/guidelines.md"
  ],
  "plugin": [],
  "tools": {
    "bash": false,
    "glob": false,
    "grep": false,
    "list": false,
    "patch": false,
    "skill": false,
    "todoread": false,
    "todowrite": false,
    "webfetch": false,
    "write": false
  },
  "formatter": {
    "scalafmt": {
      "command": [
        "scalafmt",
        "$FILE"
      ],
      "extensions": [
        ".scala",
        ".sc",
        ".sbt"
      ]
    }
  },
  "mcp": {
    "agentvibes": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "--package=agentvibes",
        "agentvibes-mcp-server"
      ]
    },
    "emacs": {
      "type": "local",
      "enabled": true,
      "command": [
        "node",
        "{env:HOME}/git/gbastkowski/mcp-emacs/bin/mcp-emacs.js",
        "--emacsclient-executable",
        "emacsclient"
      ]
    },
    "ista_jira_confluence": {
      "type": "local",
      "enabled": true,
      "command": [
        "node",
        "{env:HOME}/git/rdm/ai/mcp-jira-confluence/dist/index.js",
        "--jira-url",
        "https://ista.atlassian.net",
        "--confluence-url",
        "https://ista.atlassian.net/wiki",
        "--email",
        "gunnar.bastkowski@ista.com",
        "--token-command",
        "pass show ista/jira-api-token-mcp"
      ]
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen-coder": {
          "name": "Qwen Coder 14B",
          "variants": {
            "none": {},
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        }
      }
    }
  }
}
