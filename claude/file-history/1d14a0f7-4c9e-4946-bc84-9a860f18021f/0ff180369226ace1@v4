  readingValue: Option[ReadingValueRepr],
  unitType: Option[MdrUnitTypeRepr],
  deviceType: Option[MdrDeviceClassRepr],
  readingType: Option[MdrReadingTypeRepr],
  transportType: Option[MdrTransportTypeRepr],
  mediumType: Option[MdrMediumTypeRepr],
  measurandType: Option[MdrMeasurandRepr],
  trxSerialNumber: Option[SerialNumberRepr],
  trxArticleNumber: Option[ArticleNumberRepr],
  inputService: Option[MdrDataInputServiceTypeRepr]
)

