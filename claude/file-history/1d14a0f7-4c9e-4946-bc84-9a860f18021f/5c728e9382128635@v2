trait MeterDataRepository {

  def db: JdbcBackend#DatabaseDef
  def dbReadOnly: JdbcBackend#DatabaseDef

  /**
   * Create meter ports or update if they already exist. Idempotent - multiple calls with the same parameters
   * lead to the same result as calling once.
   *
   * This call OVERWRITES attributes of an existing meter port in the order of input configs,
   * i.e. for multiple meter port configs referring to the same meter port, the last meter port config
   * will determine the attributes of the meter port.
   *
   * Note that this call does not delete existing meter ports which are not updated.
   * So this call should be preceded by a deleteMeterPorts if the set of meter ports should be completely
   * reset.
   *
   * For now, we keep the existing ports and add new port versions.
   */
  def upsertMeterPorts(mpc: Iterable[MeterPortConfig]): Future[Done]

  /**
   * Insert the mandant for a given exec plan.
   * This makes a mandant for the plan available to views which relate the mandant to meterports, e.g.
   * for mandant specific data retention settings.
   * If a mandant mapping already exists, it is not updated.
   */
  def upsertMandantForExecPlan(execPlanId: ExecPlanID, mandantId: MandantID): Future[Done]

  /**
   * Look up the mandant registered for an execution plan
   */
  def lookupMandantForExecPlan(execPlanId: ExecPlanID): Future[Option[MandantID]]

  /**
   * Create meter port configs or update if the already exist. If the related meter port does not exist, it is created.
   *
   * This call DOES NOT OVERWRITE attributes of existing meterports EXCEPT FOR THE CERTIFICATION DATE IF IT IS NEWER.
   */
  def upsertMeterPortConfigs(mpc: Iterable[MeterPortConfig]): Future[Done]

  /**
   * For a set of meter port configs, update the validity date
   *
   * @param configValidityUpdates A list of tuples with meter port id, current validFrom and target validFrom
   */
  def updateMeterPortConfigValidities(configValidityUpdates: Iterable[(MeterPortID, LocalInstant, LocalInstant)]): Future[Done]

  /**
   * Enforce data retention policy for all meterports of a given property.
   * This includes the meterports which are not part of the current execution plan any more, e.g. because a device was
   * replaced.
   *
   * @param propertyId              The property ID to use as search key
   * @param compoundRetentionPolicy The data retention policy to enforce
   */
  def updatePropertyDataRetention(propertyId: PropertyID, compoundRetentionPolicy: CompoundRetentionPolicy): Future[Done]

  /**
   * Insert readings to the MDR.
   * Readings are automatically assigned to the correct meter port and meter port configuration based on
   * their main device ID, port number and reading date.
   *
   * @param meterReadings The reading data
   */
  def insertReadings(meterReadings: Iterable[MdrMeterPortReadingInput], overwrite: Boolean): Unit

  /**
   * Applies the given reading events which contain a reading identifier to the readings table. This can be currently
   * Revoke or Readings with an Id.
   *
   * The identifier contains a version part and an ID part. We use this to allow revokes of the IDs for a specific version which will not
   * let in any readings with an older version
   * This allows us to apply the events out of order into the database. This is not a strict requirement because kafka keeps the order
   * of the events but we use this to increase throughout and so we have more meta data available about what readings have been revoked or applied
   */
  def applyReadingEventsWithIdentifier(readingEventsWithIdentifier: Vector[MdrOutputChannelEvent]): Unit

  /**
   * Find meter ports by internal ID
   */
  def findMeterPortsById(ids: Set[MeterPortID]): Future[Vector[MdrMeterPort]]

  /**
   * Get data retention policies count
   */
  def dataRetentionPoliciesCount(): Map[CompoundRetentionPolicy, Long]

  /**
   * For a set of meter locations, find all known meter ports.
   */
  def findMeterPortsByLocation(execPlanId: Option[ExecPlanID], locations: Set[LocationId]): Future[Vector[MdrMeterPort]]

  /**
   * For a property, find all known meter ports
   */
  def findMeterPortsByProperty(execPlanId: Option[ExecPlanID], propertyId: PropertyID): Vector[MdrMeterPort]

  /**
   * For an execution plan ID, find all related meter port IDs
   */
  def findMeterPortIdsByExecPlanId(execPlanId: ExecPlanID): Vector[MeterPortID]

  /**
   * Retrieve all readings for one device-meter-port for a given timespan
   */
  def findReadingsByMeterPort(
    execPlanId: ExecPlanID,
    mainDeviceId: DeviceId,
    meterPort: PortNr,
    timespan: LocalTimespan
  ): Future[Vector[MdrMeterReading]]

  /**
   * For an execution plan ID, find all internal meter port IDs by main device ID.
   * If no exec plan ID is given, find all meter ports with matching device ID for any exec plan ID.
   *
   * Note that this includes all port numbers for all matching devices.
   */
  def findMeterPortIdsByMainDeviceIds(
    execPlanId: Option[ExecPlanID],
    devices: Set[DeviceId]
  ): Future[Vector[MeterPortID]]

  /**
   * For an execution plan ID, find all meter ports by main device ID.
   * If no exec plan ID is given, find all meter ports with matching device ID for any exec plan ID.
   *
   * Note that this includes all port numbers for all matching devices.
   */
  def findMeterPortsByMainDeviceIds(
    execPlanId: Option[ExecPlanID],
    devices: Set[DeviceId]
  ): Future[Vector[MdrMeterPort]]

  /**
   * Get all known configurations of a meter port
   */
  def getMeterPortConfigs(
    id: MeterPortID
  ): Future[Vector[MdrMeterPortConfig]]

  /**
   * For an exec plan, find all first known meter port configurations with date of first available reading
   * (required for migration)
   *
   * @return A list of tuples containing (first meterport config, first reading date)
   */
  def getFirstMeterPortConfigsWithReadingsStartByExecPlan(
    execPlanId: ExecPlanID
  ): Future[Vector[(MdrMeterPortConfig, Option[LocalInstant])]]

  /**
   * For a given set of locations, find readings from all ports of all devices
   * which are before and after the request date and within a given timespan.
   *
   * Note that for two main devices or two ports, only one result pair will be returned per location !
   * For some use cases, this may not be desired, a query based on execPlanId:main_device:port
   * or meterPortId would be required for this.
   */
  def findSurroundingReadingsByLocation(
    filterLocations: Set[LocationId],
    filterExecPlan: Option[ExecPlanID],
    filterTimespan: LocalTimespan,
    requestDate: LocalInstant
  ): Future[Vector[MdrMeterPortReading]]

  /**
   * For a given set of locations, find readings from all ports of all devices
   * which are nearest to a given timestamp within a given timespan.
   *
   * Note that for two main devices or two ports, only one result will be returned !
   * For some use cases, this may not be desired, a query based on execPlanId:main_device:port
   * or meterPortId would be required for this.
   */
  def findNearestReadingByLocation(
    filterLocations: Set[LocationId],
    filterExecPlan: Option[ExecPlanID],
    filterTimespan: LocalTimespan,
    requestDate: LocalInstant
  ): Future[Vector[MdrMeterPortReading]]

  /**
   * Retrieve readings for all ports of all main devices according to filter criteria.
   * Used by RDAS.
   *
   * @param propertyId              A property UUID for which to filter the readings.
   * @param filterDevices           A set of main device ids for which to filter the readings.
   * @param filterExecPlan          An optional execution plan id to filter the readings.
   * @param filterFrom              The local instant start time (inclusive) for filtering the readings.
   * @param filterTo                The local instant end time (exclusive) for filtering the readings
   * @param filterReadingTypes      A set of reading types. If empty, readings with any readings type will match,
   *                                else only readings will match having a type contained in the set.
   * @param filterServiceTypes      A set of service types. If empty, readings with any service type will match,
   *                                else only readings will match having a type contained in the set.
   * @param filterTransportTypes    A set of transport types. If empty, readings with any transport type will match,
   *                                else only readings will match having a type contained in the set.
   * @param filterEndOfMonth        If `false`, no effect. If `true`, only select those days which represent
   *                                the last day of the  month respectively.
   * @param anyDayReplacement       If `false`, no effect.  If `true`, per day and meter port id, only return
   *                                1 reading value from those selected by the other filters above
   *                                (without `onlyLatest`) in the priority from highest to lowest of:
   *                                - `MdrReadingType.Deadline`
   *                                - `MdrReadingType.DayEnd`
   *                                - `MdrReadingType.MonthMid`
   *                                - `MdrReadingType.MonthEnd`
   *                                - `MdrReadingType.Current`
   *                                - `MdrReadingType.Initial`
   *                                - `MdrReadingType.Removal`.
   *
   *                                Then apply `onlyLatest` if given.
   * @param onlyLatest              If `true`, returns per meter port id only the latest reading matching the other
   *                                filters, else returns all readings matching the other filters.
   * @param filterInstalled         If `true`, returns per meter port id only the latest reading matching the other
   *                                filters, else returns all readings matching the other filters.
   */
  def findReadingsByProperty(
    propertyId: PropertyID,
    filterDevices: Set[DeviceId],
    filterExecPlan: Option[ExecPlanID],
    filterFrom: LocalInstant,
    filterTo: LocalInstant,
    filterReadingTypes: Set[MdrReadingType],
    filterServiceTypes: Set[MdrReadingProcedure],
    filterTransportTypes: Set[MdrTransportType],
    filterEndOfMonth: Boolean,
    anyDayReplacement: Boolean,
    onlyLatest: Boolean,
    filterInstalled: Boolean,
  ): Vector[MdrMeterReading]

  /**
   * Retrieve all readings for all ports of all devices on a given set of locations for a given timespan
   */
  def findReadingsByLocations(
    locations: Set[LocationId],
    filterExecPlan: Option[ExecPlanID],
    timespan: LocalTimespan,
    readingTypes: Set[MdrReadingType],
    serviceTypes: Set[MdrReadingProcedure]
  ): Future[Vector[MdrMeterPortReading]]

  /**
   * Retrieve relevant readings for move in / move out.
   *
   * Note that the following assumptions apply for this method call:
   *  - Multiple meter ports can exist for one main device ID if a device is referenced in more than one execution plan
   *  - Multiple meter ports can exist for one main device ID if a device exposes more than one port number (variable type)
   *  - Nevertheless, this call will return MIMO readings for _all_ meter ports from all given main devices
   *
   * @param execPlanID            Reference to an execution plan, if any. If none is given, all meter ports are considered
   * @param locations             Set of metering points / meter locations (each may relate to more than one device)
   * @param date                  The target date
   * @param prioDaysSpan          Days before and after the target date to include into query for prio type readings
   * @param prioReadingProcedures Reading procedures to look for first
   * @param prioReadingType       Reading type to look for first
   * @param otherDaysSpan         Days before and after the target date to include into query for other type readings
   * @param fallbackSpan          Days before and after the target date to query in case no prio/other values are found for a device
   * @return Matching readings grouped by channel
   */
  def findMimoReadings(
