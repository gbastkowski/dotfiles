/**
 * Represents one port of one device installed in one location
 *
 * The tuple (ExecPlanID, DeviceId, PortNr) identifies a "lifeline" of a meter port on a location in a contract position.
 * (!) There may be multiple lifelines of the same meter port in separate contract positions (e.g. Billing, Portal)
 * (!) There may be multiple lifelines for the same meter in the same contract position (different ports)
 * (!) The same meter may exist in multiple contracts, but not at the same time.
 */
case class MdrMeterPort(
  id: Option[MeterPortID],
  // identification (pk)
  execPlanId: ExecPlanID,
  mainDeviceId: DeviceId,
  portNr: PortNr,
  // location references
  propertyId: PropertyID,
  locationId: LocationId,
  locationNumber: Option[LocationNumber],
  // config meta data
  migrated: Boolean,
  retentionPolicy: CompoundRetentionPolicy,
  // device info
  installed: LocalInstant,
  uninstalled: Option[LocalInstant],
  measurand: MdrMeasurand,
  timeZone: ZoneId,
  articleNr: ArticleNr,
  serialNr: SerialNr,
  inputService: DataInputService,
  meterUse: Option[MdrMeterUse],
  // last known certification date for this meter port
  certificationDate: Option[LocalInstant]
)

/**
 * Represents a configuration of a meter port.
 * The configuration extends a meter port by a number of device specific attributes which may change over time.
 */
case class MdrMeterPortConfig(
  // PK fields
  meterPort: MdrMeterPort,
  validFrom: LocalInstant,
  // common config fields for HCA and VOL
  deadline: Option[DeadlineDay],
  deviceType: MdrDeviceClass,
  usageUnitId: Option[UsageUnitId],
  radioArticleNr: Option[ArticleNr],
  radioSerialNr: Option[SerialNr],
  radioDeviceId: Option[DeviceId],
  migrated: Boolean,
  // HCA only fields
  hcaScale: Option[BigDecimal],
  hcaScaleFactor: Option[BigDecimal],
  hcaScaleType: Option[MdrScaleType],
  hcaZeroSetter: Option[Boolean],
  hcaSensorMode: Option[MdrSensorMode],
  // VOL only fields
  volDisplayUnit: Option[MdrUnitType],
  volPulseCapacity: Option[BigDecimal],
  volPulsePerUnit: Option[Boolean],
  volMbusAddress: Option[MbusAddress],
) {
  // The following assertions are identical to the check constraints with the same name in the database

  /*
    - if the device is a HCA
      - Scale type must always be defined
      - Scale and ZeroSetter must be defined if the scale type is not MIGRATED_UNKNOWN
      - If SensorMode is defined, scale type may not be MIGRATED_UNKNOWN (??? where does this requirement come from)

  CONSTRAINT meterport_configs_hca_positive CHECK(
      hca_scale_type = 'MIGRATED_UNKNOWN'
      OR device_type <> 'HCA'
      OR (
         hca_scale IS NOT NULL
         AND hca_scale_type IS NOT NULL
         AND hca_zero_setter IS NOT NULL
         )
)
   */
  assert(
    deviceType != MdrDeviceClass.HCA ||
    hcaScaleType.get == MdrScaleType.MIGRATED_UNKNOWN ||
    migrated ||
    (
      hcaScaleType.isDefined &&
      hcaScale.isDefined &&
      hcaZeroSetter.isDefined
      ),
    s"CONSTRAINT meterport_configs_hca_positive violated: ${pprint.apply(this)}"
  )

  /*
    - if the device is NOT a HCA, neither Scale, ScaleType, ZeroSetter or SensorMode may be defined

    CONSTRAINT meterport_configs_hca_negative CHECK (device_type = 'HCA' OR (
      hca_scale IS NULL AND
      hca_scale_type IS NULL AND
      hca_zero_setter IS NULL AND
      hca_sensor_mode IS NULL))
   */
  assert(
    deviceType == MdrDeviceClass.HCA ||
    (hcaScale.isEmpty && hcaScaleType.isEmpty && hcaScaleFactor.isEmpty && hcaZeroSetter.isEmpty && hcaSensorMode.isEmpty),
    s"CONSTRAINT meterport_configs_hca_negative violated: ${pprint.apply(this)}"
  )
}

