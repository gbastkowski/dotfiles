        )
    }
  }

  private def buildUiReadingsQuery(
    propertyIds: Vector[PropertyID],
    propertyNumbers: Vector[PropertyNumber],
    locationNumbers: Vector[LocationNumber],
    articleNumbers: Vector[ArticleNr],
    serialNumbers: Vector[SerialNr],
    deviceTypes: Vector[MdrDeviceClass],
    consumptionDateFrom: Option[ZonedDateTime],
    consumptionDateTo: Option[ZonedDateTime],
    readingTypes: Vector[MdrReadingType],
    measurandTypes: Vector[MdrMeasurand],
    lastConsumptionDateFrom: Option[ZonedDateTime],
    lastConsumptionDateTo: Option[ZonedDateTime],
    limit: Option[Int],
    dataIsforReadingsExportFeature: Boolean
  ): SqlStreamingAction[Vector[UiReadingsSearchData], UiReadingsSearchData, Effect] = {
    val serialNumbersWithoutLeadingZeros = serialNumbers.map(v => v.value.replaceFirst("^0+(?!$)", ""))
    val locationNumbersWithoutLeadingZeros = locationNumbers.map(v => v.value.replaceFirst("^0+(?!$)", ""))

    lazy val cteQuery =
      sql"""
        with removal_readings as materialized (
          select
            r.reading_date,
            r.reading_type,
            r.value,
            m.installed
          from
            property_number_lookup pnl,
            readings r
          inner join
            meterports m
          on
            r.meter_port_id = m.id
          where
            m.exec_plan_id = pnl.exec_plan_id
            and SUBSTRING(pnl.property_number, 1, 9) = any($propertyNumbers)
            and r.reading_type = 'RM'
        """
        .+?(consumptionDateFrom)(from => sql" and r.reading_date >= $from")
        .+?(consumptionDateTo)(to => sql" and r.reading_date <= $to")
        .++(sql")")

    lazy val removalReadingFilter =
      sql"""
        and not exists (
          select 1
          from removal_readings rr
          where
            rr.reading_date = r.reading_date
            and rr.reading_type = r.reading_type
            and rr.value = r.value
            and rr.installed < mp.installed
            and date(mp.installed) >= date(rr.reading_date)
        )
      """

    val propertyNumberOrUuid = (propertyIds.toList, propertyNumbers.toList) match {
      case (Nil, Nil)     => sql""
      case (ids, Nil)     => sql" and pnl.property_id = any($ids)"
      case (Nil, numbers) => sql" and SUBSTRING(pnl.property_number, 1, 9) = any($numbers)"
      case (ids, numbers) => sql" and (pnl.property_id = any($ids) or SUBSTRING(pnl.property_number, 1, 9) = any($numbers))"
    }
    val inner =
      sql"""
      SELECT
        pnl.property_number,
        pnl.property_id,
        mpcm.usage_unit_id,
        mp.id,
        mp.location_number,
        mp.location_id,
        mp.meter_port,
        mp.main_device_id,
        mp.serial_nr,
        mp.article_nr,
        mp.installed,
        mp.uninstalled,
        r.reading_date,
        r.value,
        r.unit,
        mpcm.device_type,
        r.reading_type,
        r.transport_type,
        r.medium_type,
        mp.measurand,
        mp.uninstalled,
        r.transmitting_radio_serial,
        r.transmitting_radio_article,
        mp.data_input_service
      FROM readings r RIGHT JOIN meterports mp
            on mp.id = r.meter_port_id
    """
        .+?(consumptionDateFrom)(from => sql" and r.reading_date >= $from")
        .+?(consumptionDateTo)(to => sql" and r.reading_date <= $to")
        .++(
          sql""",
           property_number_lookup pnl,
           LATERAL (SELECT DISTINCT ON (mpc.meter_port_id)
              mpc.meter_port_id,
              mpc.device_type,
              mpc.usage_unit_id,
              max(mpc.valid_from) OVER (PARTITION BY mpc.meter_port_id) as max_valid_from
          FROM meterport_configs mpc where mp.id = mpc.meter_port_id) mpcm
      WHERE mp.exec_plan_id = pnl.exec_plan_id AND
            mp.property_id = pnl.property_id
      """ ++ propertyNumberOrUuid
        )
        .+?(locationNumbersWithoutLeadingZeros)(locationNumbersVector => sql" and LTRIM(mp.location_number, '0') = any($locationNumbersVector)")
        .+?(articleNumbers)(articleNumbersVector => sql" and (mp.article_nr = any($articleNumbersVector) OR r.transmitting_radio_article = any($articleNumbersVector))")
        .+?(serialNumbersWithoutLeadingZeros)(serialNumbersVector => sql" and (LTRIM(mp.serial_nr, '0') = any($serialNumbersVector)  OR LTRIM(r.transmitting_radio_serial, '0') = any($serialNumbersVector))")
        .+?(readingTypes)(readingTypesVector => sql" and r.reading_type = any($readingTypesVector)")
        .+?(deviceTypes)(deviceTypesVector => sql" and mpcm.device_type = any($deviceTypesVector::device_type[])")
        .+?(measurandTypes)(measurandTypesVector => sql" and mp.measurand = any($measurandTypesVector)")
        .+?(lastConsumptionDateFrom)(from => sql" and mp.uninstalled >= $from")
        .+?(lastConsumptionDateTo)(to => sql" and mp.uninstalled <= $to")
        .+?(dataIsforReadingsExportFeature, removalReadingFilter)
        .+?(limit)(outputLimit => sql" limit $outputLimit")

    val query =
      if (!dataIsforReadingsExportFeature)
        sql"""
          SELECT r.*, q.payload
          FROM (""" ++ inner ++ sql""") r
                                      LEFT JOIN reading_quality_indicators q
                                      ON r.id = q.meter_port_id AND
                                      r.reading_date = q.reading_date AND
                                      r.reading_type = q.reading_type
                                      """
      else cteQuery ++ sql"SELECT r.*, null FROM (" ++ inner ++ sql") r"
    query.as[UiReadingsSearchData]
  }

