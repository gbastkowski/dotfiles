  private def addMissingMonthEndReadings(
    in: Vector[UiReadingsSearchData],
    from: Option[LocalInstant],
    to: Option[LocalInstant]): Vector[UiReadingsSearchData] = {
    lazy val consumptionDatesOrdered = in.flatMap(_.consumptionDate).sortWith(_ isBefore _)
    lazy val readingFromBoundary = consumptionDatesOrdered.headOption
    lazy val readingToBoundary = consumptionDatesOrdered.lastOption

    val requestSpecificFromBoundary = from.orElse(readingFromBoundary)
    val requestSpecificToBoundary = to.orElse(readingToBoundary)
    val readingsByMeterport = in.groupBy(_.meterPortID)
    val uniqueMeterports = in.map(UiReadingsSearchDataMeterportRef.apply).toSet

    readingsByMeterport.flatMap { case (_, readings) =>
      val referenceReading = readings.head
      val maybeInstallDate = referenceReading.installDate
      val maybeUninstallDate = referenceReading.uninstallDate.orElse {
        val locationId = referenceReading.locationId
        val portNr = referenceReading.portNr

        maybeInstallDate.flatMap { date =>
          uniqueMeterports.filter(mp =>
              mp.locationId == locationId &&
              mp.portNr == portNr &&
              mp.installDate.nonEmpty &&
              mp.installDate.get.isAfter(date)
            )
            .toList.sortWith(_.installDate.get isBefore _.installDate.get)
            .map(_.installDate.get)
            .headOption
        }
      }

      val meterportFromBoundary = (for {
        installDate <- maybeInstallDate
        requestFromDate <- requestSpecificFromBoundary
      } yield if (requestFromDate.isBefore(installDate)) installDate else requestFromDate)
        .orElse(requestSpecificFromBoundary)

      val meterportToBoundary = (for {
        uninstallDate <- maybeUninstallDate
        requestToDate <- requestSpecificToBoundary
      } yield if (requestToDate.isBefore(uninstallDate)) requestToDate else uninstallDate)
        .orElse(requestSpecificToBoundary)

      val expectedDatesWithReadings = calculateExpectedMonthEndDatesBetween(meterportFromBoundary, meterportToBoundary)
        .getOrElse(Vector.empty)
      val now = LocalInstant.now(ZoneIds.EuropeBerlin)
      val missingReadingDates = expectedDatesWithReadings
        .filterNot(d => readings.exists(_.consumptionDate.contains(d.atStartOfDay())) || d.isAfter(now))
      val fakeReadings = missingReadingDates.map { date =>
        referenceReading.copy(
          consumptionDate = Some(date),
          readingValue = None,
          readingType = Some(MdrReadingType.MonthEnd),
          qualityIndicators = None
        )
      }
      readings.filterNot(_.consumptionDate.isEmpty) ++ fakeReadings
    }.toVector
  }

  private def calculateExpectedMonthEndDatesBetween(
    from: Option[LocalInstant],
    until: Option[LocalInstant]): Option[Vector[LocalInstant]] = {

    def isLastDayOfMonth(date: LocalInstant) = {
      val currentMonthValue = date.toLocalDateTime.getMonthValue
      val monthValueForNextDay = date.plusDays(1).toLocalDateTime.getMonthValue
      monthValueForNextDay != currentMonthValue
    }

    def calculateForSameMonth(end: LocalInstant): Vector[LocalInstant] = {
      if (isLastDayOfMonth(end)) {
        // End of month is referenced - at least one month end value is expected
        Vector(end)
      } else {
        // End date doesn't cover end of month - no need to add month end value
        Vector.empty
      }
    }

    def getLastDayOfMonth(date: LocalInstant, monthsToAdd: Int): LocalInstant = {
      val endOfMonth = date.toLocalDate
        .withDayOfMonth(1)
        .plusMonths(monthsToAdd)
        .`with`(lastDayOfMonth())

      LocalInstant(endOfMonth)
    }

    for {
      start <- from
      end <- until
    } yield {
      val period = Period.between(start.toLocalDate, end.plusDays(1).toLocalDate)
      val monthsBetweenPeriod = period.getMonths + period.getYears * 12
      // Both dates referencing the same date or the period is within the same month
      if (end.isEqual(start) || monthsBetweenPeriod == 0) {
        calculateForSameMonth(end)
      } else {
        (0 to monthsBetweenPeriod).flatMap { month =>
          val date = getLastDayOfMonth(start, month)
          /*
          * - Create for each month in between an end of month entry
          * - Only create end of month value for last entry if end date is after calculated end date
          * */
          Option(date).filter(_.time <= end.time)
        }.toVector
      }
    }
  }

