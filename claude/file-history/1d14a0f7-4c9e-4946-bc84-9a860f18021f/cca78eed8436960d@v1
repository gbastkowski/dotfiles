  /**
   * Check whether readings exist for a main device
   *
   * @param filterTimespan has to be in the timezone of the meterport which is requested
   * @return
   */
  override def existReadingsByMainDevice(filterDevices: Set[DeviceId], filterTimespan: LocalTimespan,
    filterReadingTypes: Set[MdrReadingType]): Vector[MdrDeviceReadingsInfo] = monitor {
    logger.debug(s"MDR query existReadingsByMainDevice",
      "filterTimespan" -> filterTimespan, "filterReadingTypes" -> filterReadingTypes,
      "filterDevices" -> filterDevices)

    val mdrDeviceReadingsInfo = dbReadOnly.run(
      sql"""
        select distinct on (mp.main_device_id, r.reading_type)
          mp.main_device_id,
          r.reading_date,
          r.reading_type,
          mp.article_nr,
          mp.serial_nr,
          r.radio_article,
          r.radio_serial
        from
          readings_with_config as r,
          meterports as mp
        where
          mp.id = r.meter_port_id
          and mp.main_device_id = any($filterDevices)
          and r.reading_date >= ${filterTimespan.from}
          and r.reading_date < ${filterTimespan.to}
          and r.reading_type = any($filterReadingTypes)
          -- we don't want to take any readings into account that are marked as future readings
          and not exists (
            select 1
            from reading_quality_indicators as rqi
            where rqi.meter_port_id = r.meter_port_id
              and rqi.reading_date = r.reading_date
              and rqi.reading_type = r.reading_type
              and jsonb_path_exists(rqi.payload,#$qualityIndicatorsFutureQueryPath)
          )
        order by
          mp.main_device_id, r.reading_type, reading_date desc
        """.as[MdrDeviceReadingsInfo]
    )
    AwaitWithContext.result(mdrDeviceReadingsInfo, Duration.Inf)
  }

  private[impl] def findReadingsByPropertyStmt(
    propertyId: PropertyID,
    filterDevices: Set[DeviceId],
    filterExecPlan: Option[ExecPlanID],
    filterFrom: LocalInstant,
    filterTo: LocalInstant,
    filterReadingTypes: Set[MdrReadingType],
    filterServiceTypes: Set[MdrReadingProcedure],
    filterTransportTypes: Set[MdrTransportType],
    filterEndOfMonth: Boolean,
    anyDayReplacement: Boolean,
    onlyLatest: Boolean,
    filterInstalled: Boolean,
    additionalWhereClause: Option[SQLActionBuilder]) = {
    val selectStart = (anyDayReplacement, onlyLatest) match {
      case (false, false) => sql"select"
      case (true, false)  => sql"select distinct on (r.meter_port_id, reading_day)"
      case (false, true)  => sql"select distinct on (r.meter_port_id)"
      case (true, true)   => sql"""select distinct on (meter_port_id) *
                                 from (
                                   select distinct on (r.meter_port_id, reading_day)
                              """
    }

    val selectEnd = (anyDayReplacement, onlyLatest) match {
      case (false, false) => sql" order by r.reading_date asc"
      case (true, false)  => sql" order by r.meter_port_id, reading_day, reading_prio desc"
      case (false, true)  => sql" order by r.meter_port_id, reading_date desc, reading_prio desc"
      case (true, true)   => sql"""  order by r.meter_port_id, reading_day, reading_prio desc, reading_date desc
                                 ) as readings_with_and_end_of_day_logic
                                 order by meter_port_id, reading_date desc
                              """
    }

    val needsDuplicateRemovalFilter = filterReadingTypes.isEmpty || filterReadingTypes.contains(MdrReadingType.Removal)

    lazy val cteQuery =
      sql"""
        with removal_readings as materialized (
          select
            r.reading_date,
            r.reading_type,
            r.value,
            m.installed
          from
            readings_with_prio r
          inner join
            meterports m
          on
            r.meter_port_id = m.id
          where
            m.property_id = $propertyId
            and r.reading_date >= $filterFrom
            and r.reading_date < $filterTo
            and r.reading_type = 'RM'
        )
      """

    lazy val removalReadingFilter =
      sql"""
        and not exists (
          select 1
          from removal_readings rr
          where
            rr.reading_date = r.reading_date
            and rr.reading_type = r.reading_type
            and rr.value = r.value
            and rr.installed < mp.installed
            and date(mp.installed) >= date(rr.reading_date)
        )
      """

    val queryHead = if (needsDuplicateRemovalFilter) {
      cteQuery
        .++(selectStart)
    } else {
      selectStart
    }

    queryHead
      .++(
        sql"""
              r.meter_port_id,
              mp.property_id,
              mp.location_id,
              mp.meter_port,
              mp.main_device_id,
              mp.article_nr,
              mp.serial_nr,
              r.transmitting_radio_article,
              r.transmitting_radio_serial,
              r.reading_date,
              r.value,
              r.unit,
              r.reading_type,
              r.service_type,
              r.transport_type,
              r.medium_type,
              r.estimation_type,
              mp.measurand,
              mp.time_zone,
              mp.certification_date,
              r.identifier
            """)
      .+?(anyDayReplacement || onlyLatest,
        sql"""
            , date_trunc('day', r.reading_date) as reading_day
            , reading_prio
            """)
      .++(
        sql"""
                from
                  readings_with_prio as r
                inner join
                  meterports as mp
                on
                  r.meter_port_id = mp.id
                where
                  mp.property_id = $propertyId
                  and r.reading_date >= $filterFrom
                  and r.reading_date < $filterTo
                   -- we don't want to take any readings into account that are marked as future readings
                  and not exists (
                    select 1
                    from
                      reading_quality_indicators as rqi
                    where
                      rqi.meter_port_id = r.meter_port_id
                      and rqi.reading_date = r.reading_date
                      and rqi.reading_type = r.reading_type
                      and jsonb_path_exists(rqi.payload,#$qualityIndicatorsFutureQueryPath)
                  )
        """)
      .+?(needsDuplicateRemovalFilter, removalReadingFilter)
      .+?(filterEndOfMonth, sql" and date_trunc('month', r.reading_date) != date_trunc('month', r.reading_date + interval '1 days')")
      .+?(filterDevices)(deviceIds => sql" and mp.main_device_id = any($deviceIds)")
      .+?(filterExecPlan)(execPlanID => sql" and mp.exec_plan_id = $execPlanID")
      .+?(filterReadingTypes)(mdrReadingTypes => sql" and r.reading_type = any($mdrReadingTypes)")
      .+?(filterServiceTypes)(readingProcedures => sql" and r.service_type = any($readingProcedures)")
      .+?(filterTransportTypes)(transportTypes => sql" and r.transport_type = any($transportTypes)")
      .+?(filterInstalled,
        sql"""
             | and r.reading_date >= mp.installed
             | and date_trunc('day', r.reading_date) <= (
             |   select date_trunc('day', coalesce(min(installed), r.reading_date))
             |   from meterports mpi
             |   where mpi.location_id = mp.location_id and mpi.exec_plan_id = mp.exec_plan_id and mpi.installed > mp.installed
             |   -- we might have an additional meterport with the same article/serial combination due to installation date corrections
             |   -- which could result in readings not being returned if the corrected installation date is after the original installation
             |   -- date but before the reading date and the reading itself has been linked to the original meterport
             |   and not (mp.serial_nr = mpi.serial_nr and mp.article_nr = mpi.article_nr)
             |   and (mpi.migrated = false or mpi.migrated = mp.migrated)
             | )""".stripMargin) // migration handling necessary due to broken installation date for migrated meterports - see RDM-1182 for details
      .+?(additionalWhereClause)(clause => sql" and " ++ clause)
      .++(selectEnd)
  }

  private[impl] def findReadingsByPropertyInTwoStepsStmt(
    propertyId: PropertyID,
    filterDevices: Set[DeviceId],
    filterExecPlan: Option[ExecPlanID],
    filterFrom: LocalInstant,
    filterStepBoundary: LocalInstant,
    filterTo: LocalInstant,
    filterReadingTypes: Set[MdrReadingType],
    filterServiceTypes: Set[MdrReadingProcedure],
    filterTransportTypes: Set[MdrTransportType],
    filterEndOfMonth: Boolean,
    anyDayReplacement: Boolean,
    onlyLatest: Boolean,
    filterInstalled: Boolean
  ) = {

    val shortTermQuery = findReadingsByPropertyStmt(propertyId, filterDevices, filterExecPlan,
      filterStepBoundary, filterTo, filterReadingTypes, filterServiceTypes, filterTransportTypes, filterEndOfMonth,
      anyDayReplacement, onlyLatest, filterInstalled, additionalWhereClause = None)

    val longTermQuery = findReadingsByPropertyStmt(propertyId, filterDevices, filterExecPlan,
      filterFrom, filterStepBoundary, filterReadingTypes, filterServiceTypes, filterTransportTypes, filterEndOfMonth,
      anyDayReplacement, onlyLatest, filterInstalled,
      additionalWhereClause = Some(sql"not mp.id in (select meter_port_id from short_term_results)"))

    sql"""WITH short_term_results AS (""" ++
    shortTermQuery ++
    sql""") SELECT * FROM short_term_results UNION ALL (""" ++
    longTermQuery ++
    sql""")"""
  }

  override def findReadingsByProperty(
    propertyId: PropertyID,
    filterDevices: Set[DeviceId],
    filterExecPlan: Option[ExecPlanID],
    filterFrom: LocalInstant,
    filterTo: LocalInstant,
    filterReadingTypes: Set[MdrReadingType],
    filterServiceTypes: Set[MdrReadingProcedure],
    filterTransportTypes: Set[MdrTransportType],
    filterEndOfMonth: Boolean,
    anyDayReplacement: Boolean,
    onlyLatest: Boolean,
    filterInstalled: Boolean
  ): Vector[MdrMeterReading] = monitor {

    logger.debug(s"MDR query findReadingsByProperty with " +
                 s"propertyId=$propertyId filterDevices=$filterDevices filterExecplan=$filterExecPlan " +
                 s"filterFrom=$filterFrom filterTo=$filterTo filterReadingTypes=$filterReadingTypes " +
                 s"filterServiceTypes=$filterServiceTypes filterTransportTypes=$filterTransportTypes " +
                 s"filterEndOfMonth=$filterEndOfMonth anyDayReplacement=$anyDayReplacement onlyLatest=$onlyLatest")

    val fromDate = filterFrom.toLocalDate
    val toDate = filterTo.toLocalDate
    val query =
      if (onlyLatest && ChronoUnit.MONTHS.between(fromDate, toDate) >= 5) {
        val boundaryDate = toDate.`with`(firstDayOfMonth()).minus(2, ChronoUnit.MONTHS)
        findReadingsByPropertyInTwoStepsStmt(propertyId, filterDevices, filterExecPlan, filterFrom,
          LocalInstant(boundaryDate), filterTo, filterReadingTypes, filterServiceTypes, filterTransportTypes,
          filterEndOfMonth, anyDayReplacement, onlyLatest, filterInstalled)
          .as[MdrMeterReading]
      } else {
        findReadingsByPropertyStmt(propertyId, filterDevices, filterExecPlan, filterFrom, filterTo,
          filterReadingTypes, filterServiceTypes, filterTransportTypes, filterEndOfMonth,
          anyDayReplacement, onlyLatest, filterInstalled, None)
          .as[MdrMeterReading]
      }

    // TODO: This query returns the unit from the readings. There is also the display unit in the meter port config, could be a fallback ?
    // We deactivate JIT and parallel query execution to help the planner build a fast query
    // (JIT adds 2s overhead, the parallel execution another 2s)
    // There is no way to deal with this on a more global level.
    // We need postgres metrics and see what happens when we i.e. disable jit globally
    val meterReadingsF: Future[Vector[MdrMeterReading]] = dbReadOnly.run(
      dbIoActionWithLocalSetting(query, setLocalWorkMemTo4G, setLocalJitOff, setLocalMaxParallelWorkersPerGatherTo0)
    )
    AwaitWithContext.result(meterReadingsF, Duration.Inf)
  }

