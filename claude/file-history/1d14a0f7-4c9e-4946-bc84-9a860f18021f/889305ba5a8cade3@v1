  override def getMimoReadings(req: MimoReadingsRequest): Try[MimoReadingsResponse] = Try {
    mimoRequestsCounter.increment()

    def mapMeterPortsToLocations(portReadings: Iterable[MdrMeterPortReadingsResult]) = {
      portReadings
        .groupBy(p => (p.meterPort.locationId, p.meterPort.portNr))
        .collect {
          case ((_, _), portResults) if portResults.nonEmpty =>
            if (portResults.size > 1) {
              logger.warn(s"Unclear: Found more than 1 port for a location in MIMO result: [$portResults]. " +
                          s"Using first port found.")
            }
            val portResult = portResults.head
            if (portResult.readings.size > 2) {
              logger.warn(s"Unclear: Found more than 2 readings for one port in MIMO result: [$portResult]. " +
                          s"Returning first 2 readings prioritized by reading type.")
            }
            portResult.readings.toVector
              .sortBy(_.readingType).take(2)
              .map(reading => MdrMimoMappings.mapMimoReading(portResult, reading))
        }.flatten.toVector
    }

    logger.debug(s"getMimoReadings with request: $req")

    val mimoReadings = meterDataRepository.findMimoReadings(
      None,
      req.locationUUIDs,
      req.tenantChangeDate,
      req.daysMoveInMoveOut,
      Set(MdrReadingProcedure.Intermediate),
      MdrReadingType.Current,
      req.daysOther,
      fallbackSpan = 31
    )

    if (mimoReadings.portResults.exists(_.meterPort.timeZone != req.zoneId)) {
      logger.error(s"The timezone of at least one of the readings does not match the timezone of the request." +
                   s"Request tz: ${req.zoneId} " +
                   s"Meter ports: ${
                     mimoReadings.portResults
                       .filter(_.meterPort.timeZone != req.zoneId)
                       .map(_.meterPort.mainDeviceId)
                   }")
      throw new MdrInvalidTimeZoneException("The timezone of at least one of the readings does not match " +
                                            "the timezone of the request. See log for details.")
    }

    mimoReadings match {
      case MdrReadingsResult(None, _)                      =>
        MimoReadingsResponse(None, Vector.empty)
      case MdrReadingsResult(bundleDate, meterPortResults) =>
        MimoReadingsResponse(bundleDate, mapMeterPortsToLocations(meterPortResults))
    }
  }

  /**
   * Retrieve readings according to the `RdasReadingsRequest`.
   * Used by RDAS.
   *
   * @param req The `RdasReadingsRequest` containing the filter information
   * @return One of:
   *  - `Success[RdasReadingsRequest]` if no error occurred,
   *  - `Failure[MdrInvalidParametersException]` if
   *    - timezones of `filterTimespan` do not match.
   *    - both `filterDevices` AND `filterProperty` are empty.
   *  - `Failure[MdrInvalidTimeZoneException]` if the timezone of a received reading
   *    does not match the timezone in `filterTimespan`.
   */
  override def getRdasReadings(req: RdasReadingsRequest): Try[RdasReadingsResponse] =
    getRdasReadings(req, MdrRdasMappings.mapToRdasMeterPorts(calibrationCheck))

  // real implementation needed to be able to replace mapToRdasMeterPorts during testing.
  private[api] def getRdasReadings(req: RdasReadingsRequest,
    mapToRdasMeterPorts: Vector[MdrMeterReading] => Vector[RdasMeterPort])
  : Try[RdasReadingsResponse] = Try {
    logger.debug(s"Received readings request: $req")

    rdasRequestsCounter.increment()

    val requestTimeZone = req.startTime.getZone
    if (requestTimeZone != req.endTime.getZone)
      throw new MdrInvalidParametersException("Only timespans with the same ZoneId in from and to are allowed.")

    val propertyId = PropertyID(req.propertyId)
    val filterDevices = req.filterDevices.map(DeviceId(_))

    val mdrMeterReadings = meterDataRepository.findReadingsByProperty(
      propertyId,
      filterDevices,
      filterExecPlan = None, // get readings for all exec plans
      LocalInstant(req.startTime),
      LocalInstant(req.endTime),
      MdrRdasMappings.mapRequestReadingTypes(req.filterReadingTypes),
      filterServiceTypes = Set.empty, // get readings for all service types
      // RDM-1158 filtering of transport types based on "limited/idx" was removed
      // however, the findReadingsByProperty signature was kept as-is on purpose
      // todo remove during SQDD06-2439
      filterTransportTypes = Set.empty,
      filterEndOfMonth = req.filterReadingTypes.contains(ANY_END_OF_MONTH),
      anyDayReplacement = req.filterReadingTypes.contains(ANY_END_OF_MONTH) ||
                          req.filterReadingTypes.contains(ANY_END_OF_DAY),
      onlyLatest = req.filterLastReading,
      filterInstalled = req.filterByInstallationDates
    )

    if (mdrMeterReadings.exists(_.timeZone != requestTimeZone)) {
      logger.error(s"The timezone of at least one of the readings does not match the timezone of the request." +
                   s"Request tz: $requestTimeZone. " +
                   s"Readings: ${mdrMeterReadings.filter(_.timeZone != requestTimeZone)}")
      throw new MdrInvalidTimeZoneException("The timezone of at least one of the readings does not match " +
                                            "the timezone of the request. See log for details.")
    }

    RdasReadingsResponse(req.propertyId, propertyNr = None, mapToRdasMeterPorts(mdrMeterReadings))
  }

