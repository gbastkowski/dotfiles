{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "statusLine": {
    "type": "command",
    "command": "ccline",
    "padding": 0
  },
  "enabledPlugins": {
    "jira-assistant@mdb": true,
    "gitlab-assistant@mdb": true,
    "ista-presentation@ista-marketplace": true,
    "caveman@caveman": true,
    "mcp-emacs@mcp-emacs": true
  },
  "extraKnownMarketplaces": {
    "mcp-emacs": {
      "source": {
        "source": "github",
        "repo": "gbastkowski/mcp-emacs"
      }
    },
    "mdb": {
      "source": {
        "source": "git",
        "url": "git@gitlab.com:ista-se/cas/dsp-mdb/ai-tooling/marketplace.git"
      }
    },
    "ista-marketplace": {
      "source": {
        "source": "git",
        "url": "git@gitlab.com:ista-se/cas/dsp/ai-dev-tools/marketplace.git"
      }
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "atuin hook claude-code"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "atuin hook claude-code"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "atuin hook claude-code"
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": false,
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "voiceEnabled": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754085994342
  }
}
