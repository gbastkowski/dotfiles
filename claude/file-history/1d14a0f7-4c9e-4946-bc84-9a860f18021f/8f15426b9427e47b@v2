        implicit def shrinkNonEmptySet[A]: Shrink[Set[A]] = Shrink.shrinkContainer[Set, A].suchThat(_.nonEmpty)

        // Each reading input must have a unique key of (meter_port_id, reading_date, reading_type) in the readings database
        // table. Thus to generate the reading input values such that they are not overwritten during inserting, they must
        // also have such unique key.
        // These test fixtures only use a single meter port id, thus only the combination of consumptionDate
        // (called reading_date in the database) and readingType must be unique.
        // This type describes a unique key for a reading input.
        type ReadingInputKey = (LocalInstant, MdrReadingType)

        // A generator for a single reading input key (consumptionDate, readingType) tuple.
        val genReadingInputKey: Gen[ReadingInputKey] = Gen.zip(genLocalInstant, genMdrReadingType)

        // From a set of unique reading input key tuples, generate the unique reading inputs.
        // First, for each tuple of (consumptionDate, readingType), create a generator which transforms that single
        // (consumptionDate, readingType) tuple to a single reading input.
        // Then transform that set of generators to a single generator of an iterable of reading inputs.
        def genUniqueReadingInputs(uniqueReadingInputKeys: Set[ReadingInputKey]): Gen[Seq[MdrMeterPortReadingInput]] = {
          val gensOfReadingInput = uniqueReadingInputKeys.map {
            case (consumptionDate, readingType) => genMdrMeterPortReadingInput(consumptionDate, readingType)
          }

          Gen.sequence[Seq[MdrMeterPortReadingInput], MdrMeterPortReadingInput](gensOfReadingInput)
        }

        // First create a non-empty set of such key tuples. Then from these tuples, create the readings.
        val genNonEmptyReadingInputs: Gen[Iterable[MdrMeterPortReadingInput]] = for {
          uniqueKeys <- Gen.nonEmptyContainerOf[Set, ReadingInputKey](genReadingInputKey)
          readingInputs <- genUniqueReadingInputs(uniqueKeys)
        } yield readingInputs

