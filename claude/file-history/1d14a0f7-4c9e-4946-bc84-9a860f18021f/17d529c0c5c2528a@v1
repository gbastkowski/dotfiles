  /**
   * Try to convert the current url filter to a real component state parsing the plain string query
   * Failing on this process cannot affect the readings search functionality, so in case of error we log it a ignore the url filter params setting the state to the current one
   *
   * @param filterParams the stringfied version of the state fo the component
   * @return
   */
  def filterParamsFromUrl(filterParams: Option[String]): State = {

    //clean the list of values for a enum type in order to have a clean list of tuple in the for of ("literalNameValueType", comma separated values string)
    def sanitizedListOfValues(values: Seq[String], prefix: String): Seq[(String, String)] =
      URIUtils.decodeURIComponent(values.mkString("")).split("\\);\\(").toSeq
        .map(v => v.replace(")", "").replace("(", ""))
        .map { tup =>
          val tupleValue = tup.split(",")
          (tupleValue.head, t(s"$prefix.${tupleValue.head}"))
        }

    def sanitizeList(values: Seq[String]): Seq[(String)] =
      URIUtils.decodeURIComponent(values.mkString("")).split(",").toSeq

    Try {
      filterParams match {
        case Some(filters) =>
          val filterValueList = filters.split("&").filter(_.nonEmpty)
          filterValueList.foldLeft(State()) { (acc, next) =>
            val candidate = next.split("=").toSeq
            (candidate.head, candidate.tail) match {
              case ("pn", values)   => acc.copy(propertyNumberField = sanitizeList(values))
              case ("ln", values)   => acc.copy(locationNumberField = sanitizeList(values))
              case ("a", values)    => acc.copy(articleField = sanitizeList(values))
              case ("sn", values)   => acc.copy(serialNumberField = sanitizeList(values))
              case ("dt", values)   => acc.copy(deviceTypeField = sanitizedListOfValues(values, "ReadingsSearchLoc.Enums.Devicetype"))
              case ("cdf", values)  => acc.copy(consumptionDateFromField = values.headOption)
              case ("cdt", values)  => acc.copy(consumptionDateToField = values.headOption)
              case ("rt", values)   => acc.copy(readingTypeField = sanitizedListOfValues(values, "ReadingsSearchLoc.Enums.ReadingType"))
              case ("m", values)    => acc.copy(measurandField = sanitizedListOfValues(values, "ReadingsSearchLoc.Enums.Measurands"))
              case ("uu", values)   => acc.copy(usageUnitField = sanitizeList(values))
            }
          }
        case None          => State()
      }
    }.getOrElse {
      println("Error reading the url filter params received for the component")
      State()
    }
  }

  /**
   * Try to convert the current filter to a url string
   * Failing on this process cannot affect the readings search functionality, so in case of error we log it a ignore the url filter params
   *
   * @param s the state of the component
   * @return
   */
  def filterParamsToUrl(s: State): Option[String] = {
    def stringfiedSeq(field: String, input: Seq[String]) = {
      if (input.isEmpty) ""
      else s"$field=${URIUtils.encodeURIComponent(input.mkString(","))}&"
    }

    def stringfiedSeqOfTuples(field: String, input: Seq[(String, String)]) = {
      val prefix = field match {
        case "dt"                  => "ReadingsSearchLoc.Enums.Devicetype"
        case "rt"                  => "ReadingsSearchLoc.Enums.ReadingType"
        case "m"                   => "ReadingsSearchLoc.Enums.Measurands"
        case no_short_name_defined => ""
      }
      if (input.isEmpty) ""
      else s"$field=${URIUtils.encodeURIComponent(input.map(v => (v._1, t(s"$prefix.${v._1}"))).mkString(";"))}&"
    }

    Try {
      if (s.isEmpty) None
      else {
        Option(
          stringfiedSeq("pn", s.propertyNumberField) +
          stringfiedSeq("ln", s.locationNumberField) +
          stringfiedSeq("a", s.articleField) +
          stringfiedSeq("sn", s.serialNumberField) +
          stringfiedSeqOfTuples("dt", s.deviceTypeField) +
          s.consumptionDateFromField.map(v => s"cdf=${URIUtils.encodeURIComponent(v)}&").getOrElse("") +
          s.consumptionDateToField.map(v => s"cdt=${URIUtils.encodeURIComponent(v)}&").getOrElse("") +
          stringfiedSeqOfTuples("rt", s.readingTypeField) +
          stringfiedSeqOfTuples("m", s.measurandField) +
          s.lastConsumptionDateFromField.map(v => s"lcdf=${URIUtils.encodeURIComponent(v)}&").getOrElse("") +
          s.lastConsumptionDateToField.map(v => s"lcdt=${URIUtils.encodeURIComponent(v)}&").getOrElse("") +
          stringfiedSeq("uu", s.usageUnitField)
        )
      }
    }.getOrElse {
      println("Error generating the url filter params applied in the component")
      None
    }
  }

  private def dispatchLoadReadingsSearch(p: Props, s: State): Callback =
  {
    val propertyIds = s.propertyNumberField.flatMap(toPropertyId).map(PropertyIdRepr.apply)
    val propertyNumbers = s.propertyNumberField.filter(isPropertyNumber).map(v => PropertyNumberRepr(v.take(9)))
    p.readingsSearchModelP.dispatchCB(
      LoadReadingsSearch(
        ReadingsSearchReqRepr(
          propertyIds = propertyIds.toVector,
          propertyNumbers = propertyNumbers.toVector,
          locationNumbers = s.locationNumberField.map(LocationNumberRepr).toVector,
          articleNumbers = s.articleField.map(ArticleNumberRepr).toVector,
          serialNumbers = s.serialNumberField.map(SerialNumberRepr).toVector,
          deviceTypes = mapRequestDeviceClassesType(s.deviceTypeField.toVector),
          consumptionDateFrom = s.consumptionDateFromField.map(w => LocalDate.parse(w, dateFormatter).atStartOfDay(DateTimeDisplay.defaultDisplayZoneId)),
          consumptionDateTo = s.consumptionDateToField.map(w => LocalDate.parse(w, dateFormatter).atStartOfDay(DateTimeDisplay.defaultDisplayZoneId).`with`(LocalTime.MAX)),
          readingTypes = mapRequestReadingType(s.readingTypeField.toVector),
          measurandTypes = mapRequestMeasurand(s.measurandField.toVector),
          lastConsumptionDateFrom = Option.empty,
          lastConsumptionDateTo = Option.empty,
          usageUnits = s.usageUnitField.map(UsageUnitNumberRepr).toVector,
          Option(p.frontendConfig.readingsComponents.outputLimit)
        )
      ))
  }

  private def toPropertyId(s: String): Option[UUID] = 
    if (ReadingsSearchPropertyConverter.isUuidWithOptionalHyphen(s)) 
      ReadingsSearchPropertyConverter.sanitizePropertyId(s).toOption
    else 
      None

  private def isPropertyNumber(s: String) = ReadingsSearchPropertyConverter.isValidPropertyNumber(s)

  def apply(
    router: RouterCtl[Loc],
    readingsSearchModelP: ModelProxy[Pot[ReadingsExtendedRespRepr]],
    execEnvNameRepr: ExecEnvNameRepr,
    filterParams: Option[String],
    localeModelP: ModelProxy[Pot[Locale]],
    frontendConfig: FrontendConfig
  ) =
    component(Props(router, readingsSearchModelP, execEnvNameRepr, filterParams, localeModelP, frontendConfig))

  private val component = ScalaComponent.builder[Props]("ReadingsSearch")
    .initialStateFromProps(p => filterParamsFromUrl(p.filterParams))
    .renderBackend[Backend]
    .componentDidMount { cdm =>
      val validationResult = validateInput(cdm.state)
      //Allow to perform a search if a filter is in the url and is valid, the first time loading the component
      Callback.when(cdm.props.filterParams.nonEmpty && validationResult.isSuccess)(dispatchLoadReadingsSearch(cdm.props, cdm.state)) >> PropertyNumberFieldRef.foreach(_.focus()) >>
      // Show an error toast if the filterParams are not empty but the validation is not a success
      Callback.when(cdm.props.filterParams.nonEmpty && !validationResult.isSuccess)(browserNotification(validationResult.error))
    }
    .componentDidUpdate(cdu =>
      //In case of pasting a URL with params we need to set an special behaviour here
      Callback.when(cdu.prevProps.filterParams =!= cdu.currentProps.filterParams && cdu.currentState == cdu.prevState) {
        val newState = filterParamsFromUrl(cdu.currentProps.filterParams)
        val validationResult = validateInput(newState)

        cdu.setState(newState) >>
        //clear the results in case of a empty filter loaded by url
        Callback.when(cdu.currentProps.filterParams.isEmpty)(cdu.currentProps.readingsSearchModelP.dispatchCB(ClearReadingsSearch)) >>
        //force an automatic search in case the url is pasted with some filter and the filter is valid
        Callback.when(cdu.currentProps.filterParams.nonEmpty && validationResult.isSuccess)(dispatchLoadReadingsSearch(cdu.currentProps, newState)) >>
        // Show an error toast if the filterParams are not empty but the validation is not a success
        Callback.when(cdu.currentProps.filterParams.nonEmpty && !validationResult.isSuccess)(browserNotification(validationResult.error))
      }
    )
    .componentWillUnmount(cwu =>
      cwu.props.readingsSearchModelP.dispatchCB(ClearReadingsSearch)
    )
    .build

  private def browserNotification(msg: String, `type`: String = "error"): Callback =
    Callback(Toast.Toastify.toast(msg, Toast.Props(`type` = `type`)))


}
