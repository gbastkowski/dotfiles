  override def getUiReadings(req: ReadingsSearchReq): Try[ReadingsSearchRespRepr] = {
    Try {
      // To prevent producing slow queries, we validate that at least one of the expected primary keys is defined in the request
      if (req.propertyIds.isEmpty && req.propertyNumbers.isEmpty && req.locationNumbers.isEmpty)
        throw ApiErrors.BadRequest("invalid request payload")

      val readingsSearchData = meterDataRepository.getUiReadings(
        req.propertyIds,
        req.propertyNumbers,
        req.locationNumbers,
        req.articleNumbers,
        req.serialNumbers,
        MdrUiMappings.mapRequestDeviceTypes(req.deviceTypes),
        req.consumptionDateFrom,
        req.consumptionDateTo,
        MdrUiMappings.mapRequestReadingTypes(req.readingTypes),
        MdrUiMappings.mapRequestMeasurand(req.measurandTypes),
        req.lastConsumptionDateFrom,
        req.lastConsumptionDateTo,
        req.limit
      )
      val readingSearchDataWithMissingReadings = addMissingMonthEndReadings(
        in = readingsSearchData,
        from = req.consumptionDateFrom.map(LocalInstant.apply),
        to = req.consumptionDateTo.map(LocalInstant.apply))

      ReadingsSearchRespRepr(
        metaData = ReadingsMetaData(req.limit.contains(readingSearchDataWithMissingReadings.size)),
        data = MdrUiMappings.mapUiReadingsSearchDataToRepr(readingSearchDataWithMissingReadings))
    }
  }

  override def saveRequestForUiReadingsExport(req: ReadingsSearchReq): Try[ReadingsExportRespRepr] = {
    Try {
      if (
        req.propertyNumbers.isEmpty || // at least one property number must be defined
        req.propertyNumbers.size > 1000 || // max 1k properties are allowed
        req.consumptionDuration.fold(true)(_ > 13) || // consumption dates must be defined and max duration of 13 months is allowed
        req.readingTypes.isEmpty // at least one reading type must be present
      ) throw ApiErrors.BadRequest("invalid request payload")

      val id = meterDataRepository.saveRequestForUiReadingsExport(
        req.propertyNumbers,
        req.locationNumbers,
        req.articleNumbers,
        req.serialNumbers,
        MdrUiMappings.mapRequestDeviceTypes(req.deviceTypes),
        req.consumptionDateFrom.get,
        req.consumptionDateTo.get,
        MdrUiMappings.mapRequestReadingTypes(req.readingTypes),
        MdrUiMappings.mapRequestMeasurand(req.measurandTypes),
        req.lastConsumptionDateFrom,
        req.lastConsumptionDateTo
      )
      ReadingsExportRespRepr(id.get)
    }
  }

  override def getUiReadingsForExport(id: String): Try[Source[ByteString, NotUsed]] = {
