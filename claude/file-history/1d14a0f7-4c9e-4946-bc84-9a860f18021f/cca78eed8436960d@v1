  override def getUiReadingsForExport(id: String): Source[UiReadingsSearchData, NotUsed] = {
    try {
      getAndDeleteReadingsExportReference(id) match {
        case None      => throw ReadingsExportIdNotFound(id)
        case Some(ref) =>
          val query = buildUiReadingsQuery(
            propertyIds = Vector.empty,
            propertyNumbers = ref.request.propertyNumbers,
            locationNumbers = ref.request.locationNumbers,
            articleNumbers = ref.request.articleNumbers,
            serialNumbers = ref.request.serialNumbers,
            deviceTypes = ref.request.deviceTypes,
            consumptionDateFrom = Some(ref.request.consumptionDateFrom.toZonedDateTimeUTC),
            consumptionDateTo = Some(ref.request.consumptionDateTo.toZonedDateTimeUTC),
            readingTypes = ref.request.readingTypes,
            measurandTypes = ref.request.measurandTypes,
            lastConsumptionDateFrom = ref.request.lastConsumptionDateFrom.map(_.toZonedDateTimeUTC),
            lastConsumptionDateTo = ref.request.lastConsumptionDateTo.map(_.toZonedDateTimeUTC),
            limit = None,
            dataIsforReadingsExportFeature = true)

          val publisher = dbReadOnly.stream(
            query
              .withStatementParameters(
                fetchSize = 1000,
                rsType = ResultSetType.ForwardOnly,
                rsConcurrency = ResultSetConcurrency.ReadOnly,
                statementInit = _.setQueryTimeout(120),
              )
              .transactionally
          )
          Source.fromPublisher(publisher)
      }
    } catch {
      case e @ (_: ReadingsExportIdNotFound | _: TimeoutException) =>
        throw e.withMeta("requestReferenceId" -> id)
    }
  }

