    private def onSearch(p: Props, s: State) = {
      p.readingsSearchModelP.dispatchCB(ClearReadingsSearch) >> {
        validateInput(s) match {
          case _ @ ValidationResult(true, _, _)         => dispatchLoadReadingsSearch(p, s)
          case _ @ ValidationResult(false, errorMsg, _) =>
            println(s"Search button display/hidden functionality failed: $errorMsg")
            browserNotification(errorMsg)
        }
      }
    }

