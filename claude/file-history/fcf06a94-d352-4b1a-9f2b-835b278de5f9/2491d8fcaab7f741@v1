  "EmitterMdrRgcServiceImpl.getRdasReadings" should {

    trait SUT extends SUTWithStubbedFindReadingsByProperty {

      def genSetOfEnumTypes[T <: EnumEntry](`enum`: enumeratum.Enum[T]): Gen[Set[T]] =
        Gen.containerOf[Set, T](Gen.oneOf(`enum`.values))

      lazy val genRdasRequestReadingType: Gen[Set[RdasRequestReadingType]] = genSetOfEnumTypes(RdasRequestReadingType)
      lazy val genSetUuids: Gen[Set[UUID]] = Gen.containerOf[Set, UUID](genUuid)
      lazy val genBoolean: Gen[Boolean] = Gen.oneOf(true, false)

      lazy val genValidRdasReadingsRequest: Gen[RdasReadingsRequest] = for {
        propertyId <- genUuid
        instant1 <- genInstant
        instant2 <- genInstant
        zoneId <- genZoneId
        Seq(startTime, endTime) = Seq(instant1, instant2).sorted.map(ZonedDateTime.ofInstant(_, zoneId))
        filterReadingTypes <- genRdasRequestReadingType
        filterDevices <- genSetUuids
        filterLastReading <- genBoolean
        filterInstalled <- genBoolean
      } yield RdasReadingsRequest(propertyId, startTime, endTime, filterReadingTypes, filterDevices, filterLastReading, filterInstalled)

    }

    "fail when given request startTime and endTime have different time zones" in new SUT {
      private val genZonedDateTime: Gen[ZonedDateTime] = for {
        instant <- genInstant
        zoneId <- genZoneId
      } yield ZonedDateTime.ofInstant(instant, zoneId)

      private val genMoreThan6Parameters: Gen[(UUID, Set[UUID], ZonedDateTime, ZonedDateTime,
        Set[RdasRequestReadingType], Boolean, Boolean)] = for {
        propertyId <- genUuid
        filterDevices <- genSetUuids
        startTime <- genZonedDateTime
        endTime <- genZonedDateTime suchThat (_.getZone != startTime.getZone)
        filterReadingTypes <- genRdasRequestReadingType
        filterLastReading <- genBoolean
        filterInstalled <- genBoolean
      } yield (propertyId, filterDevices, startTime, endTime, filterReadingTypes, filterLastReading, filterInstalled)

      forAll(genMoreThan6Parameters) {
        case (propertyId, filterDevices, startTime, endTime, filterReadingTypes, filterLastReading, filterInstalled) =>
          whenever(startTime.getZone != endTime.getZone) {
            val request = RdasReadingsRequest(propertyId, startTime, endTime, filterReadingTypes, filterDevices,
              filterLastReading, filterInstalled)
            val _try = emitterMdrRgcService.getRdasReadings(request)
            inside(_try) {
              case Failure(exception) =>
                exception shouldBe a[MdrInvalidParametersException]
                exception.getMessage shouldEqual "Only timespans with the same ZoneId in from and to are allowed."
            }
          }
      }
    }

    "succeed when given request startTime and endTime have same time zones" in new SUT {
      forAll(genValidRdasReadingsRequest) { rdasReadingsRequest =>
        whenever(rdasReadingsRequest.startTime.getZone == rdasReadingsRequest.endTime.getZone) {
          // We do not check the request parameters, as this is outside of the scope of this unit test.
          // We return an empty readings set, as otherwise we would also need to test all transformation logic
          // happening inside EmitterMdrRgcServiceImpl how to transform a MdrMeterReading to a
          // RdasReadingsResponse, which is outside of the scope of this unit test.
          stubMockMdr(Vector.empty)
          val _try = emitterMdrRgcService.getRdasReadings(rdasReadingsRequest)
          assert(_try.isSuccess)
        }
      }
    }

    "forward request parameters to MeterDataRepository.findReadingsByMainDeviceOrProperty method " +
    "thereby transforming RdasReadingsRequest to correct request parameters, " +
    "and interpreting ANY_END_OF_DAY and ANY_END_OF_MONTH" in new SUT {
      forAll(genValidRdasReadingsRequest) { rdasReadingsRequest =>
        whenever(rdasReadingsRequest.startTime.getZone == rdasReadingsRequest.endTime.getZone) {
          val filterDevices = rdasReadingsRequest.filterDevices.map(DeviceId(_))
          val propertyID = PropertyID(rdasReadingsRequest.propertyId)
          val expectedFilterEndOfMonth = rdasReadingsRequest.filterReadingTypes
            .contains(RdasRequestReadingType.ANY_END_OF_MONTH)
          val expectedAnyDayReplacement = expectedFilterEndOfMonth ||
                                          rdasReadingsRequest.filterReadingTypes
                                            .contains(RdasRequestReadingType.ANY_END_OF_DAY)
          val expectedMdrReadingType = mapRequestReadingTypes(rdasReadingsRequest.filterReadingTypes)
          // RDM-1158, filtering transport type depending on the value of "limited/idx" was removed
          // however, the findReadingsByProperty signature was kept as-is on purpose
          // todo during SQDD06-2439
          val expectedTransportTypes: Set[MdrTransportType] = Set.empty

          // We do check the request parameters.
          // But we return an empty readings set, as otherwise we would also need to test all transformation logic
          // happening inside EmitterMdrRgcServiceImpl how to transform a MdrMeterReading to a
          // RdasReadingsResponse, which is outside of the scope of this unit test.
          when(mockMdr.findReadingsByProperty(
            propertyID,
            filterDevices,
            filterExecPlan = None,
            LocalInstant(rdasReadingsRequest.startTime),
            LocalInstant(rdasReadingsRequest.endTime),
            filterReadingTypes = expectedMdrReadingType,
            filterServiceTypes = Set.empty,
            filterTransportTypes = expectedTransportTypes,
            expectedFilterEndOfMonth,
            expectedAnyDayReplacement,
            onlyLatest = rdasReadingsRequest.filterLastReading,
            filterInstalled = rdasReadingsRequest.filterByInstallationDates
          )).thenReturn(Vector.empty)

          val _try = emitterMdrRgcService.getRdasReadings(rdasReadingsRequest)
          assert(_try.isSuccess)
        }
      }
    }

    "fail when MDR returns a reading with a different timezone than used in startTime and endTime" in new SUT {
      forAll(genValidRdasReadingsRequest, genMdrMeterReadingsAnyTimeZone) {
        case (rdasReadingsRequest, mdrMeterReadings) =>
          val requestTimeZone = rdasReadingsRequest.startTime.getZone
          whenever(requestTimeZone == rdasReadingsRequest.endTime.getZone &&
                   mdrMeterReadings.exists(_.timeZone != requestTimeZone)) {
            // We do not check the request parameters, as this is outside of the scope of this unit test.
            // but we check the reaction on the returned mdrMeterReadings which have a timezone problem
            stubMockMdr(mdrMeterReadings)

            val _try = emitterMdrRgcService.getRdasReadings(rdasReadingsRequest)
            inside(_try) {
              case Failure(exception) =>
                exception.getMessage shouldEqual ("The timezone of at least one of the readings does not match " +
                                                  "the timezone of the request. See log for details.")
            }
          }
      }
    }

    "return replies from MeterDataRepository.findReadingsByMainDeviceOrProperty method " +
    "transformed via given mapToRdasMeterPorts method" in new SUT {
      // use the actual implementation rather than the trait so that the testable version of getRdasReadings is usable
      private val emitterMdrRgcServiceImpl = newEmitterMdrRgcServiceImpl(mock[DeadlineDeviceCheck])

      private val genRdasReading: Gen[RdasReading] = for {
        zone <- genZoneId
        date <- genInstant.map(ZonedDateTime.ofInstant(_, zone))
        value <- genDouble.map(BigDecimal.valueOf)
        readingType <- genFromEnum(RdasReadingType)
        channel <- Gen.option(genFromEnum(RdasChannelType))
        medium <- Gen.option(genFromEnum(RdasMediumType))
        flags <- genBoolean.map(RdasReadingFlags(_))
      } yield RdasReading(date, value, readingType, channel, medium, flags)

      private val genRdasMeterPort: Gen[RdasMeterPort] = for {
        locationId <- genUuid
        port <- genPortNr
        mainDeviceId <- genUuid
        mainArticleNr <- genArticleNrString
        mainSerialNr <- genSerialNrString
        radioArticleNr <- Gen.option(genArticleNrString)
        radioSerialNr <- Gen.option(genSerialNrString)
        measurand <- genFromEnum(MdrMeasurand).map(_.entryName)
        unit <- genFromEnum(MdrUnitType).map(_.entryName)
        rdasReadings <- Gen.containerOf[Vector, RdasReading](genRdasReading)
      } yield
        RdasMeterPort(locationId, port, mainDeviceId, mainArticleNr, mainSerialNr,
          None, radioArticleNr, radioSerialNr, measurand, unit, rdasReadings)

      private val genRdasMeterPorts: Gen[Vector[RdasMeterPort]] = Gen.containerOf[Vector, RdasMeterPort](genRdasMeterPort)

      forAll(genValidRdasReadingsRequest, genMdrMeterReadingsAnyTimeZone, genRdasMeterPorts) {
        case (rdasReadingsRequest, mdrMeterReadings, rdasMeterPorts) =>
          val requestTimeZone = rdasReadingsRequest.startTime.getZone
          whenever(requestTimeZone == rdasReadingsRequest.endTime.getZone) {
            val mdrMeterReadingsFixedTimezone = mdrMeterReadings.map(r => r.copy(timeZone = requestTimeZone))
            // We do not check the request parameters, as this is outside of the scope of this unit test.
            // but we check that the returned mdrMeterReadings are forwarded to given mapToRdasMeterPorts method.
            stubMockMdr(mdrMeterReadingsFixedTimezone)

            def verifyMapToRdasMeterPorts(mdrMeterReadings: Vector[MdrMeterReading]): Vector[RdasMeterPort] = {
              mdrMeterReadings shouldEqual mdrMeterReadingsFixedTimezone
              rdasMeterPorts
            }

            val _try = emitterMdrRgcServiceImpl.getRdasReadings(rdasReadingsRequest, verifyMapToRdasMeterPorts)
            inside(_try) {
              case Success(RdasReadingsResponse(propertyId, None, returnedRdasMeterPorts)) =>
                propertyId shouldEqual rdasReadingsRequest.propertyId
                returnedRdasMeterPorts shouldEqual rdasMeterPorts
            }
          }
      }
    }

