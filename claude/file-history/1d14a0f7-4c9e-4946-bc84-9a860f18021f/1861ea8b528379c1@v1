  private def findMeterPort(execPlanId: ExecPlanID, mainDeviceId: DeviceId, portNr: PortNr): Option[(MeterPortID, FakeMeterPortInternal)] = {
    val result = _meterPorts
      .filter(p => p._2.meterPort.execPlanId == execPlanId && p._2.meterPort.mainDeviceId == mainDeviceId && p._2.meterPort.portNr == portNr)

    assert(result.size <= 1, s"More than one meter port found for plan=$execPlanId device=$mainDeviceId port=$portNr")

    result.headOption
  }

  private def findMeterPortId(execPlanId: ExecPlanID, mainDeviceId: DeviceId, port: PortNr): Option[MeterPortID] =
    findMeterPort(execPlanId, mainDeviceId, port).map(_._1)

  private def findMeterPortAndConfig(
    execPlanId: ExecPlanID,
    mainDeviceId: DeviceId,
    portNr: PortNr,
    consumptionDate: LocalInstant
  ): Option[(MeterPortID, MdrMeterPort, MdrMeterPortConfig)] = {
    findMeterPort(execPlanId, mainDeviceId, portNr).map {
      case (portId, result) =>
        val config = result.configs
          .sortBy(_.validFrom)
          .findLast(c => c.validFrom.isEqual(consumptionDate) || c.validFrom.isBefore(consumptionDate))

        assert(config.isDefined, s"No valid config found for consumption date $consumptionDate (candidates were valid from ${result.configs.map(_.validFrom)})")
        (portId, result.meterPort, config.get)
    }
  }

  private def mapMeterReadingInput(
    portDef: MdrMeterPort,
    portConfig: MdrMeterPortConfig,
    in: MdrMeterPortReadingInput
  ): MdrMeterReading = {
    MdrMeterReading(
      meterPortId = portDef.id.get,
      propertyId = portDef.propertyId,
      locationId = portDef.locationId,
      port = portDef.portNr,
      mainDeviceId = portDef.mainDeviceId,
      mainArticleNr = portDef.articleNr,
      mainSerialNr = portDef.serialNr,
      radioArticleNr = portConfig.radioArticleNr,
      radioSerialNr = portConfig.radioSerialNr,
      consumptionDate = in.consumptionDate,
      value = in.value,
      unit = in.unit,
      readingType = in.readingType,
      readingProcedure = in.readingProcedure,
      transportType = in.transportType,
      mediumType = in.mediumType,
      estimationType = in.estimationType,
      measurand = portDef.measurand,
      timeZone = portDef.timeZone,
      certificationDate = portDef.certificationDate,
      identifier = in.identifier.map(_.toJson)
    )
  }

  // note: overwrite has no effect, readings are simply appended !
  override def insertReadings(meterReadings: Iterable[MdrMeterPortReadingInput], overwrite: Boolean): Unit = {
    meterReadings.foreach { reading =>
      findMeterPortAndConfig(reading.execPlanId, reading.mainDeviceId, reading.port, reading.consumptionDate).foreach {
        case (id, portDef, portConfig) =>
          val mappedReading = mapMeterReadingInput(portDef, portConfig, reading)
          val oldReadings = _readings.getOrElse(id, List.empty[MdrMeterReading])
          _readings.put(id, oldReadings :+ mappedReading)
      }
    }
  }

  override def applyReadingEventsWithIdentifier(readingEventsWithIdentifier: Vector[MdrOutputChannelEvent]): Unit = {
    val revokedReadings = readingEventsWithIdentifier.collect { case e: MdrMeterPortReadingRevoke => e }
    revokedReadings.foreach { revokedReading =>
      _readings.mapValuesInPlace { case (_, v) =>
        v.filterNot { r =>
          r.identifier.map(_.-("version")).contains(revokedReading.identifier.toUnversionedJson) &&
          r.identifier.nonEmpty &&
          (r.identifier.get \ "version").as[Int] <= revokedReading.identifier.version
        }
      }
      _revokedReadings.addOne(revokedReading.identifier)
    }

    readingEventsWithIdentifier
      .collect { case e: MdrMeterPortReadingInput => e }
      .groupBy(_.identifier.get)
      .toList
      .foreach { case (identifier, readings) =>
        // check if the reading identifier was already revoked. If yes we do not need to insert the readings, If not we can just insert them
        if (!_revokedReadings.contains(identifier))
          insertReadings(readings, overwrite = true)
      }

    ()
  }

  override def findReadingsByMeterPort(
    execPlanId: ExecPlanID,
    mainDeviceId: DeviceId,
    portNr: PortNr,
    timespan: LocalTimespan
  ): Future[Vector[MdrMeterReading]] = {
    val result = findMeterPortId(execPlanId, mainDeviceId, portNr).map { meterPort =>
      _readings
        .getOrElse(meterPort, List.empty)
        .filter(r => timespan.contains(r.consumptionDate))
        .sortBy(_.consumptionDate)
        .toVector
    }.getOrElse(Vector.empty)

    Future.successful(result)
  }

