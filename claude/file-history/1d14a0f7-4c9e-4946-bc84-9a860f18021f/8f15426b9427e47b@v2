    "set initial and current data retention correctly" in {
      val device = createDevice("00003", "103")
      // first config with default policy: set current and initial to DEFAULT
      val mpc1 = createHcaMeterPortConfig(device, Some(createDevice("10001", "201")), property1, propertyNumber1, usageUnit1, location3, locationNumber1, instDate1, meterPortZoneId)
      // second config with default policy: keep DEFAULT
      val mpc2 = mpc1.copy(retentionPolicy = CompoundRetentionPolicy.DEFAULT)
      // third config with non-default policy: keep DEFAULT in initial and update current
      val mpc3 = mpc1.copy(retentionPolicy = CompoundRetentionPolicy.NO_DAILY_VALUES_OTHER_DEFAULT)
      // 4th config with non-default policy: keep DEFAULT in initial and update current
      val mpc4 = mpc1.copy(retentionPolicy = CompoundRetentionPolicy.DAILY_VALUES_5_YEARS_OTHER_DEFAULT)

      // initial setup with default retention, update with default retention
      for {
        _ <- mdr.truncateReadings()
        _ <- mdr.truncateMeterPortsTable()
        _ <- mdr.upsertMeterPorts(Vector(mpc1))
        vs1 <- mdr.getInitialAndCurrentRetentionPolicy(Some(mpc1.execPlanId), Set(mpc1.mainDeviceId))
        _ <- mdr.upsertMeterPorts(Vector(mpc2))
        vs2 <- mdr.getInitialAndCurrentRetentionPolicy(Some(mpc2.execPlanId), Set(mpc2.mainDeviceId))
        _ <- mdr.upsertMeterPorts(Vector(mpc3))
        vs3 <- mdr.getInitialAndCurrentRetentionPolicy(Some(mpc3.execPlanId), Set(mpc3.mainDeviceId))
        _ <- mdr.upsertMeterPorts(Vector(mpc4))
        vs4 <- mdr.getInitialAndCurrentRetentionPolicy(Some(mpc4.execPlanId), Set(mpc4.mainDeviceId))
      } yield {
        vs1 should contain theSameElementsAs Vector((mpc1.mainDeviceId, CompoundRetentionPolicy.DEFAULT, CompoundRetentionPolicy.DEFAULT))
        vs2 should contain theSameElementsAs Vector((mpc2.mainDeviceId, CompoundRetentionPolicy.DEFAULT, CompoundRetentionPolicy.DEFAULT))
        vs3 should contain theSameElementsAs Vector((mpc3.mainDeviceId, CompoundRetentionPolicy.DEFAULT, CompoundRetentionPolicy.NO_DAILY_VALUES_OTHER_DEFAULT))
        vs4 should contain theSameElementsAs Vector((mpc4.mainDeviceId, CompoundRetentionPolicy.DEFAULT, CompoundRetentionPolicy.DAILY_VALUES_5_YEARS_OTHER_DEFAULT))
      }
    }

