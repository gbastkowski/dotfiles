  def deleteMeterPortsForExecPlanCascade(execPlanId: ExecPlanID): Unit = monitor {
    val deletePorts = sqlu"DELETE FROM meterports WHERE exec_plan_id = $execPlanId"
    val deleteMandant = sqlu"DELETE FROM exec_plan_mandants WHERE exec_plan_id = $execPlanId"
    val deleteProperty = sqlu"DELETE FROM property_number_lookup WHERE exec_plan_id = $execPlanId"
    AwaitWithContext.result(db.run(DBIO.seq(deletePorts, deleteMandant, deleteProperty)), Duration.Inf)
    ()
  }

