        p4 should have size 8

        // HCAs should have no cert date set
        p4.find(_.serialNr == SerialNr("101")).get.meterUse shouldBe Some(MdrMeterUse.MAIN_METER)
        p4.find(_.serialNr == SerialNr("102")).get.meterUse shouldBe Some(MdrMeterUse.USAGE_UNIT_METER)
        p4.find(_.serialNr == SerialNr("103")).get.meterUse shouldBe Some(MdrMeterUse.MAIN_METER)
        p4.find(_.serialNr == SerialNr("104")).get.meterUse shouldBe Some(MdrMeterUse.USER_GROUP_METER)
        p4.find(_.serialNr == SerialNr("105")).get.meterUse shouldBe Some(MdrMeterUse.COMMON_METER)

        // VOLs should have cert dates if set in initial configs
        p4.find(_.serialNr == SerialNr("301")).get.meterUse shouldBe Some(MdrMeterUse.USER_GROUP_METER)
        p4.find(_.serialNr == SerialNr("302")).get.meterUse shouldBe Some(MdrMeterUse.USAGE_UNIT_METER)
        p4.find(_.serialNr == SerialNr("303")).get.meterUse shouldBe Some(MdrMeterUse.MAIN_METER)
      }
    }

    "store and retrieve reading values for a meter port" in {
      val readingsCount = 10
      val intervalSeconds = 60
      val valueStep = 0.1

      val readings = meterPortConfigs1
        .flatMap(mp => createReadings(mp, readingsCount, instDate1, intervalSeconds, valueStep))

      val timespan = LocalTimespan(instDate1, instDate1.plusSeconds((intervalSeconds * readingsCount) + 1))

      for {
        _ <- mdr.truncateReadings()
        _ <- mdr.truncateMeterPortsTable()
        _ <- mdr.upsertMeterPorts(meterPortConfigs1)
        result = mdr.insertReadings(readings)
        _ = mdr.insertReadings(readings) // inserting them twice to also check here that duplicates are not allowed
        retrieved <- Future.traverse(meterPortConfigs1) { mp =>
          mdr.findReadingsByMeterPort(mp.execPlanId, mp.mainDeviceId, mp.portNr, timespan)
        }
      } yield {
        result shouldBe()
        super[PostgresSpec].forAll(retrieved) { results =>
          results should have size 10
          super[PostgresSpec].forAll(results) { r =>
            // check static attributes of readings
            r.readingType shouldBe MdrReadingType.DayEnd
            r.unit shouldBe MdrUnitType.UnitUndefined
            r.measurand shouldBe MdrMeasurand.HeatingHCA
            r.port shouldBe PortNr(2)
            r.propertyId shouldBe property1
            r.estimationType shouldBe MdrEstimationType.NoEstimation
          }
          // check readings
          results.map(_.value) shouldBe Range.BigDecimal.apply(valueStep, valueStep * (readingsCount + 1), valueStep)
          // check dates
          results.map(_.consumptionDate) shouldBe (0 until readingsCount).map(i => instDate1.plusSeconds(i * intervalSeconds))
        }
      }
    }

