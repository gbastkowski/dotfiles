      case MdrTransportType.CACTUS  => MdrTransportTypeRepr.CACTUS
    }

    private def mapToMdrDataInputServiceRepr(in: DataInputService): MdrDataInputServiceTypeRepr = in match {
      case DataInputService.LGSTRUGET_SERVICE           => MdrDataInputServiceTypeRepr.LGSTRUGET_SERVICE
      case DataInputService.COMPETITOR_TAKEOVER_SERVICE => MdrDataInputServiceTypeRepr.COMPETITOR_TAKEOVER_SERVICE
    }

    private def mapToMdrMediumType(in: MdrMediumType): MdrMediumTypeRepr = in match {
      case MdrMediumType.OPTICAL       => MdrMediumTypeRepr.OPTICAL
      case MdrMediumType.RADIO         => MdrMediumTypeRepr.RADIO
      case MdrMediumType.MANUAL        => MdrMediumTypeRepr.MANUAL
      case MdrMediumType.RADIO_CLASSIC => MdrMediumTypeRepr.RADIO_CLASSIC
      case MdrMediumType.OTHER         => MdrMediumTypeRepr.OTHER
    }

    private def mapToMdrUnitType(in: MdrUnitType): MdrUnitTypeRepr = in match {
      case MdrUnitType.UnitGC        => MdrUnitTypeRepr.UnitGC
      case MdrUnitType.UnitJ         => MdrUnitTypeRepr.UnitJ
      case MdrUnitType.UnitKJ        => MdrUnitTypeRepr.UnitKJ
      case MdrUnitType.UnitGJ        => MdrUnitTypeRepr.UnitGJ
      case MdrUnitType.UnitKWH       => MdrUnitTypeRepr.UnitKWH
      case MdrUnitType.UnitMWH       => MdrUnitTypeRepr.UnitMWH
      case MdrUnitType.UnitM3        => MdrUnitTypeRepr.UnitM3
      case MdrUnitType.UnitL         => MdrUnitTypeRepr.UnitL
      case MdrUnitType.UnitDevice    => MdrUnitTypeRepr.UnitDevice
      case MdrUnitType.UnitUndefined => MdrUnitTypeRepr.UnitUndefined
    }

    private def mapToMeterUseRepr(in: MdrMeterUse): MdrMeterUseRepr = in match {
      case MdrMeterUse.MAIN_METER       => MdrMeterUseRepr.MAIN_METER
      case MdrMeterUse.USER_GROUP_METER => MdrMeterUseRepr.USER_GROUP_METER
      case MdrMeterUse.COMMON_METER     => MdrMeterUseRepr.COMMON_METER
      case MdrMeterUse.USAGE_UNIT_METER => MdrMeterUseRepr.USAGE_UNIT_METER
    }

    def mapUiReadingsSearchDataToRepr(in: Vector[UiReadingsSearchData]): Vector[ReadingsSearchDataRepr] = in.map { v =>
      ReadingsSearchDataRepr(
        propertyNumber = PropertyNumberRepr(v.propertyNumber.value),
        propertyId = PropertyIdRepr(v.propertyId.value),
        usageUnitId = v.usageUnitId.map(id => UsageUnitIdRepr(id.value)),
        locationNumber = v.locationNumber.map(s => LocationNumberRepr(s.value)),
        locationId = LocationIdRepr(v.locationId.value),
        mainDeviceId = DeviceIdRepr(v.mainDeviceId.value),
        serialNumber = v.serialNumber.map(s => SerialNumberRepr(s.value)),
        articleNumber = v.articleNumber.map(s => ArticleNumberRepr(s.value)),
        consumptionDate = v.consumptionDate.map(v => LocalInstantRepr(v.time)),
        readingValue = v.readingValue.map(ReadingValueRepr(_)),
        unitType = v.unit.map(mapToMdrUnitType),
        deviceType = Option(mapToDeviceTypeRepr(v.deviceType)),
        readingType = v.readingType.map(mapToReadingTypeRepr),
        transportType = v.transportType.map(mapToMdrTransportTypeRepr),
        mediumType = v.mediumType.map(mapToMdrMediumType),
        measurandType = Option(mapToMeasurandRepr(v.measurandType)),
        lastConsumptionDate = v.lastConsumptionDate.map(t => LocalInstantRepr(t.time)),
        trxSerialNumber = v.trxSerialNumber.map(s => SerialNumberRepr(s.value)),
        trxArticleNumber = v.trxArticleNumber.map(s => ArticleNumberRepr(s.value)),
        qualityIndicators = mapQualityIndicator(v.qualityIndicators),
        inputService = Option(mapToMdrDataInputServiceRepr(v.inputService))
      )
    }

    private def mapQualityIndicator(input: Option[JsObject]): Set[EmitterQualityIndicator] =
      input.fold[Set[EmitterQualityIndicator]](Set.empty) { js =>
        Try((js \ "indicators").as[List[QualityIndicator]]) match {
          case Success(list) => list.map { obj =>
            EmitterQualityIndicator(obj.entryName, obj.description)
          }.toSet
          case Failure(e)    =>
            logger.warn("MDR returned readings with qualityIndicator but underlying payload has wrong " +
                        s"format and could not be passed", "error" -> e)
            Set.empty

        }
      }
  }
}

trait EmitterMdrRgcServiceImplMetrics {
  def rdmMeterRegistry: MeterRegistry

  val rdasRequestsCounter: Counter = rdmMeterRegistry.counter("rdasRequests")
  val mimoRequestsCounter: Counter = rdmMeterRegistry.counter("mimoRequests")
  val mimoRequestCount = new AtomicLong(0)
}
