        p2.find(_.serialNr == SerialNr("302")).get.meterUse shouldBe Some(MdrMeterUse.USAGE_UNIT_METER)
        p2.find(_.serialNr == SerialNr("303")).get.meterUse shouldBe Some(MdrMeterUse.MAIN_METER)

