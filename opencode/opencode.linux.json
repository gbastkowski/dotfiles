{
  "$schema": "https://opencode.ai/config.json",
  "model": "mistral/mistral-medium-latest",
  "small_model": "mistral/mistral-medium-latest",
  "instructions": [
    "AGENTS.md",
    "CLAUDE.md",
    "CONTRIBUTING.md",
    "docs/guidelines.md"
  ],
  "plugin": [
    "@zenobius/opencode-skillful",
    "oh-my-opencode@latest"
  ],
  "tools": {
    "bash": true,
    "glob": true,
    "grep": true,
    "list": true,
    "patch": true,
    "skill": true,
    "todoread": true,
    "todowrite": true,
    "webfetch": true,
    "write": true
  },
  "formatter": {
    "scalafmt": {
      "command": [
        "scalafmt",
        "$FILE"
      ],
      "extensions": [
        ".scala",
        ".sc",
        ".sbt"
      ]
    }
  },
  "mcp": {
    "agentvibes": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "--package=agentvibes",
        "agentvibes-mcp-server"
      ]
    },
    "emacs": {
      "type": "local",
      "enabled": true,
      "command": [
        "node",
        "/home/gunnar/git/gbastkowski/mcp-emacs/bin/mcp-emacs.js",
        "--emacsclient-executable",
        "/usr/bin/emacsclient"
      ]
    }
  },
  "provider": {
    "mistral": {
      "npm": "@ai-sdk/mistral",
      "name": "Mistral AI",
      "options": {
        "apiKey": "{env:MISTRAL_API_KEY}"
      },
      "models": {
        "mistral-medium-latest": {
          "name": "Mistral Medium (Latest)",
          "variants": {
            "none": {},
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        },
        "mistral-large-latest": {
          "name": "Mistral Large (Latest)",
          "variants": {
            "none": {},
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        },
        "magistral-medium-latest": {
          "name": "Magistral Medium (Latest)",
          "variants": {
            "none": {},
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        }
      }
    }
  }
}
