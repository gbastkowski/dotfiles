  }

  override def getMonthlyPropertyReadingsStatus(propertyId: PropertyID): Vector[MdrPropertyReadingsStatusMonthly] = {
    propertyReadingsStatusMonthly.collect { case ((propertyId, _, _), v) if propertyId == propertyId => v }.toVector
  }

