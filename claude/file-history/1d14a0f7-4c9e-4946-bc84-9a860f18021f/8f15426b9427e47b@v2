  // Compare MDR input data with retrieved data, matching relevant domain attributes
  private def compare(in: MdrMeterPortReadingInput, res: MdrMeterReading): Boolean = {
    in.consumptionDate == res.consumptionDate &&
    in.mainDeviceId == res.mainDeviceId &&
    in.port == res.port &&
    in.value == res.value &&
    in.unit == res.unit &&
    in.readingType == res.readingType &&
    in.readingProcedure == res.readingProcedure &&
    in.transportType == res.transportType &&
    in.mediumType == res.mediumType &&
    in.estimationType == res.estimationType &&
    in.radioArticle == res.radioArticleNr &&
    in.radioSerial == res.radioSerialNr
  }
