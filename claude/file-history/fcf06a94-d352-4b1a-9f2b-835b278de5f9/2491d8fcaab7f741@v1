    // are converted correctly.
    "group mdrMeterReadings by meterPortId - check reading values are converted correctly" in new SUT {
      // This test for correct mapping re-uses domain code to map reading type, channel type and medium type.
      // This means that these mappings themselves are not unit-tested.
      // This may be acceptable seen that the mapping mechanics are straight-forward,
      // thus the mapping implementation itself is the domain specification.
      // This test also re-uses isOutOfCalibration from the domain code, which should be ok, as there are specific
      // unit tests on this method.
      private def isReadingSource(rdasReading: RdasReading)(mdrMeterReading: MdrMeterReading): Boolean =
        rdasReading.date == mdrMeterReading.consumptionDate.toZonedDateTime(mdrMeterReading.timeZone) &&
        rdasReading.value == mdrMeterReading.value &&
        rdasReading.readingType == mapResponseReadingType(mdrMeterReading.readingType) &&
        rdasReading.channel.contains(mapResponseChannelType(mdrMeterReading.transportType)) &&
        rdasReading.medium == mapResponseMediumType(mdrMeterReading.mediumType) &&
        rdasReading.flags == RdasReadingFlags(isOutOfCalibration(stubCalibrationCheck)(mdrMeterReading))

      forAll(genMdrMeterReadingsAnyTimeZone) { mdrMeterReadings =>
        val meterPortIdMdrMeterReadingsMap = mdrMeterReadings.groupBy(groupingKey)

        val meterPortIdRdasMeterPortMap = mapToMeterPortIdRdasMeterPortMap(stubCalibrationCheck)(mdrMeterReadings)

        meterPortIdRdasMeterPortMap.foreach {
          case (groupingKey, rdasMeterPort) =>
            val sourceMdrMeterReadings = meterPortIdMdrMeterReadingsMap(groupingKey)
            rdasMeterPort.readings.foreach { rdasReading =>
              assert(sourceMdrMeterReadings.exists(isReadingSource(rdasReading)))
            }
        }
      }
    }

