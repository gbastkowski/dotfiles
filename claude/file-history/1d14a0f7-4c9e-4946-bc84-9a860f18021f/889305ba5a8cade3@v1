  override def getMimoReadings2(mimoRequest: MimoRequest): Try[MimoResponse] = Try {

    def serviceHealthCheckRequest(mimoRequest: MimoRequest): Boolean = {
      // This is a special case for the health check request.
      // Parameter values are same as configured in bundle-configs repo: kubernetes/templates/emitter-mdr-rgc/ingress-service-health-mdr-rgc-mimo.yml
      mimoRequest.locations.size == 1 &&
      mimoRequest.locations.head.value.toString == "00000000-0000-0000-0000-000000000000" &&
      mimoRequest.mimoDate.value == LocalDate.of(1900, 1, 1) &&
      mimoRequest.propertyNumber.isDefined &&
      mimoRequest.propertyNumber.get.value == "0123456789"
    }

    val requestLocations = mimoRequest.locations
    val billingPeriodEndValueVariant = mimoRequest.billingPeriodEndValueVariant.getOrElse(false)
    val mdrMimoReadings = if (billingPeriodEndValueVariant)
      meterDataRepository.findBillingPeriodEndValueQuirk(
        requestDate = mimoRequest.mimoDate.value,
        locations = requestLocations.map(_.value).map(LocationId(_)).toSet
      )
    else
      meterDataRepository.findMimoReadings2(
        mimoDate = mimoRequest.mimoDate.value,
        locations = requestLocations.map(_.value).map(LocationId(_)).toSet
      )
    val receivedLocationsReadings = mdrMimoReadings
      .groupBy(_.locationId)
      .map { case receivedLocationId -> mdrMimoReadings =>
        val responseLocationId = Uuid(receivedLocationId.value)
        val maybeMainSerialNumber = mdrMimoReadings.head.mainSerialNr.map(_.value).map(SerialNumber(_))
        val mimoReadings = mdrMimoReadings.map(mdrMimoReading =>
          MimoReading(
            readingDate = Date(mdrMimoReading.readingLocalInstant.toLocalDate),
            readingValue = ReadingValue(mdrMimoReading.readingValue.doubleValue),
            readingUnit = ReadingUnit(mdrMimoReading.readingUnit.entryName),
            readingType = ReadingType(mdrMimoReading.readingType.entryName),
            measurand = mimoreadings.Measurand(mdrMimoReading.measurand.entryName),
            mimoType = MimoType((mdrMimoReading.readingType, mdrMimoReading.readingProcedure) match {
              case (_, MdrReadingProcedure.CustomerSelfReading)               => OpenApiMimoType.SelfReading.entryName
              case (MdrReadingType.Current, MdrReadingProcedure.Intermediate) => OpenApiMimoType.IntermediateReading.entryName
              case _                                                          => OpenApiMimoType.OtherReading.entryName
            })
          )
        )
        responseLocationId -> LocationReadings(locationId = responseLocationId, mainSerialNumber = maybeMainSerialNumber, readings = mimoReadings.toList)
      }
    val allLocationsReadings = requestLocations.map(locationId =>
      receivedLocationsReadings
        .getOrElse(
          locationId, LocationReadings(locationId, mainSerialNumber = None, readings = List.empty))
    )

    // We don't want to publish metrics for the health check request
    if (!serviceHealthCheckRequest(mimoRequest)) {
      publishMimoMetrics(billingPeriodEndValueVariant, requestLocations.size, receivedLocationsReadings.size, mdrMimoReadings)
    }
    MimoResponse(mimoRequest.propertyNumber, mimoRequest.mimoDate, allLocationsReadings, billingPeriodEndValueVariant = None)
  }

  /**
   * Retrieve readings for given property within the specified dates.
   * Used by IstaNext/Code Juno.
   *
   * @param propertyUuid The Property UUID
   * @param startDate    Start Date. format - full-date notation as defined by RFC 3339, for example, 2017-07-21
   * @param endDate      End Date (Inclusive) - full-date notation as defined by RFC 3339, for example, 2017-07-21
   * @return One of:
   *  - `Success[Response]` if no error occurred,
   *  - `Failure[MdrInvalidParametersException]` if
   *    - Property not specified.
   */
  override def getPropertyReadings(propertyUuid: UUID, startDate: LocalDate, endDate: LocalDate): Try[Response] =
    getPropertyReadings(propertyUuid, startDate, endDate, PropertyReadingsMappings.mapToPropertyReadingsMeterPorts())

  // real implementation needed to be able to replace mapToPropertyReadingsMeterPorts during testing.
  private[api] def getPropertyReadings(propertyUuid: UUID, startDate: LocalDate, endDate: LocalDate,
    mapToPropertyReadingsMeterPorts: ArraySeq[MdrMeterReading] => ArraySeq[MeterPort]): Try[Response] = Try {
    val propertyId = PropertyID(propertyUuid)

    def findReadingsFromMeterDataRepository(readingTypes: Set[MdrReadingType]) =
      meterDataRepository.findReadingsByProperty(
        propertyId,
        filterDevices = Set.empty,
        filterExecPlan = None,
        filterFrom = LocalInstant(startDate),
        // the filterTo is the point in time (exclusive) but the endDate is inclusive and thus, adding 1 day
        filterTo = LocalInstant(endDate.plusDays(1L)),
        filterReadingTypes = readingTypes,
        filterServiceTypes = Set.empty,
        filterTransportTypes = Set.empty,
        filterEndOfMonth = false,
        anyDayReplacement = true,
        onlyLatest = false,
        filterInstalled = true,
      )


    // Readings with all reading types
    val mdrMeterReadings: ArraySeq[MdrMeterReading] =
      distinctMerge(
        findReadingsFromMeterDataRepository(Set(MdrReadingType.Initial)), // Readings with Initial reading type
        findReadingsFromMeterDataRepository(Set.empty)) // Readings with all reading types

    Response(propertyUuid, startDate, endDate, mapToPropertyReadingsMeterPorts(mdrMeterReadings))
  }

  private def distinctMerge[T](A: Vector[T], B: Vector[T]): ArraySeq[T] = {
    val small = Seq(A, B).minBy(_.size)
    val large = Seq(A, B).maxBy(_.size)

    // ArraySeq.unsafeWrapArray(large.view.filterNot(small.contains) ++ small)

    ArraySeq.untagged.from(large.view.filterNot(small.contains) ++ small)
  }

  private def publishMimoMetrics(
    billingPeriodEndValueVariant: Boolean,
    numberOfRequestedLocations: Int,
    numberOfReceivedLocationsReadings: Int,
    mdrMimoReadings: Seq[MdrMimoReading]): Unit = {

    val metricName = if (billingPeriodEndValueVariant) "Billing.billingPeriodEndValueQuirk" else "Billing.mimo"
    val locationMetrics = Map(
      "requested_locations" -> numberOfRequestedLocations.toString,
      "filled_locations" -> numberOfReceivedLocationsReadings.toString,
      "unfilled_locations" -> (numberOfRequestedLocations - numberOfReceivedLocationsReadings).toString
    )

    val allReadingLabels = if (billingPeriodEndValueVariant) billingPeriodEndValueQuirkReadingLabels else mimoReadingLabels

    val actualReadingLabelWithCounts: Map[String, String] =
      mdrMimoReadings.groupBy(_.readingLabel.entryName)
        .view.mapValues(_.size.toString).toMap

    val readingLabelMetrics = allReadingLabels.map(label => label.entryName -> actualReadingLabelWithCounts.getOrElse(label.entryName, "0")).toMap

    val meterPortMetrics = mdrMimoReadings.headOption.map(mdrMimoReading =>
      Map(
        "location_measurands_to_fill" -> mdrMimoReading.locationMeasurandsToFill.toString,
        "ambiguous_location_measurands_to_fill" -> mdrMimoReading.ambiguousLocationMeasurandsToFill.toString,
        "duplicated_devices_on_other_locations_considered" -> mdrMimoReading.duplicatedDevicesOnOtherLocationConsidered.toString
      )).getOrElse(Map(
      "location_measurands_to_fill" -> "0",
      "ambiguous_location_measurands_to_fill" -> "0",
      "duplicated_devices_on_other_locations_considered" -> "0"
    ))

    val totalMetrics = locationMetrics ++ readingLabelMetrics ++ meterPortMetrics

    businessMetricsProducer.writeEvents(
      MetricEvent(
        metricName,
        totalMetrics,
        Instant.now(),
        COUNTER,
        mimoRequestCount.incrementAndGet()
      )
    )
  }

}

