  val propertyReadingsStatus: TrieMap[PropertyID, MdrPropertyReadingsStatus] = TrieMap()
  val propertyReadingsStatusMonthly: TrieMap[(PropertyID, ExecPlanID, YearMonth), MdrPropertyReadingsStatusMonthly] = TrieMap()

  override def upsertPropertyReadingsStatus(statuus: Iterable[MdrPropertyReadingsStatus]): Future[Done] = {
    statuus.foreach { status =>
      propertyReadingsStatus.put(status.propertyId, status)

      val period = YearMonth.from(status.updated.toLocalDate)
      propertyReadingsStatusMonthly.update((status.propertyId, status.execPlanId, period), MdrPropertyReadingsStatusMonthly(
        status.execPlanId,
        status.propertyId,
        period,
        status.updated,
        status.timeZone,
        status.ppsYield,
        status.receivable,
        status.notReceived,
      ))
    }
    Future.successful(Done)
  }

  override def getPropertyReadingsStatus(properties: Set[PropertyID]): Vector[MdrPropertyReadingsStatus] = {
