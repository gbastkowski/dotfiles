{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/kimi-k2.6",
  "small_model": "opencode-go/deepseek-v4-flash",
  "instructions": [
    "CLAUDE.md",
    "CONTRIBUTING.md",
    "docs/guidelines.md"
  ],
  "plugin": [
    "@zenobius/opencode-skillful",
    "oh-my-openagent@latest"
  ],
  "tools": {
    "bash": true,
    "glob": true,
    "grep": true,
    "list": true,
    "patch": true,
    "skill": true,
    "todoread": true,
    "todowrite": true,
    "webfetch": true,
    "write": true
  },
  "formatter": {
    "scalafmt": {
      "command": [
        "scalafmt",
        "$FILE"
      ],
      "extensions": [
        ".scala",
        ".sc",
        ".sbt"
      ]
    }
  },
  "mcp": {
    "agentvibes": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "--package=agentvibes",
        "agentvibes-mcp-server"
      ]
    },
    "emacs": {
      "type": "local",
      "enabled": true,
      "command": [
        "node",
        "/Users/gunnar.bastkowski/git/gbastkowski/mcp-emacs/bin/mcp-emacs.js",
        "--emacsclient-executable",
        "/opt/homebrew/bin/emacsclient"
      ]
    },
    "ista_jira_confluence": {
      "type": "local",
      "enabled": true,
      "command": [
        "node",
        "/Users/gunnar.bastkowski/git/rdm/ai/mcp-jira-confluence/dist/index.js",
        "--jira-url",
        "https://ista.atlassian.net",
        "--confluence-url",
        "https://ista.atlassian.net/wiki",
        "--email",
        "gunnar.bastkowski@ista.com",
        "--token-command",
        "pass show ista/jira-api-token-mcp"
      ]
    }
  },
  "provider": {
    "mistral": {
      "npm": "@ai-sdk/mistral",
      "name": "Mistral AI",
      "options": {
        "apiKey": "{env:MISTRAL_API_KEY}"
      },
      "models": {
        "mistral-medium-latest": {
          "name": "Mistral Medium (Latest)",
          "variants": {
            "none": {},
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        },
        "mistral-large-latest": {
          "name": "Mistral Large (Latest)",
          "variants": {
            "none": {},
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        },
        "magistral-medium-latest": {
          "name": "Magistral Medium (Latest)",
          "variants": {
            "none": {},
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        }
      }
    }
  }
}
