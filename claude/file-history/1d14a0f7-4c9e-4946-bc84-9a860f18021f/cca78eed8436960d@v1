        r.value,
        r.unit,
        r.reading_type,
        r.service_type,
        r.transport_type,
        r.medium_type,
        r.estimation_type,
        r.identifier
      from
        readings as r,
        meterports as mp
      where
        mp.id = r.meter_port_id
        and mp.location_id = any($filterLocations)
        and r.reading_date >= ${filterTimespan.from}
        and r.reading_date < ${filterTimespan.to}
