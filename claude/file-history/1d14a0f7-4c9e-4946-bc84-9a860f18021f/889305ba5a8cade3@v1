    // this implementation forgets about the original grouping by MeterPortID, thus it is difficult to test.
    def mapToRdasMeterPorts(calibrationCheck: CalibrationCheck)
      (mdrMeterReadings: Vector[MdrMeterReading]): Vector[RdasMeterPort] =
      mapToMeterPortIdRdasMeterPortMap(calibrationCheck)(mdrMeterReadings).values.toVector

    // TODO SQDD06-2147/SQDD06-2442 get rid of this grouping key
    // it was introduced so that we can remove the aggregation of radio and unit without the need to change the
    // source code too much, but it is probably not needed if we change more of the consuming source code
    case class GroupingKey(
      locationId: LocationId,
      port: PortNr,
      mainDeviceId: DeviceId,
      mainArticleNr: ArticleNr,
      mainSerialNr: SerialNr,
      radioArticleNr: Option[ArticleNr],
      radioSerialNr: Option[SerialNr],
      measurand: MdrMeasurand,
      unit: MdrUnitType
    )

    def groupingKey(mdrMeterReading: MdrMeterReading): GroupingKey =
      GroupingKey(
        mdrMeterReading.locationId,
        mdrMeterReading.port,
        mdrMeterReading.mainDeviceId,
        mdrMeterReading.mainArticleNr,
        mdrMeterReading.mainSerialNr,
        mdrMeterReading.radioArticleNr,
        mdrMeterReading.radioSerialNr,
        mdrMeterReading.measurand,
        mdrMeterReading.unit
      )

    // real implementation needed to be able to better reason about the mapping during testing.
    def mapToMeterPortIdRdasMeterPortMap(calibrationCheck: CalibrationCheck)
      (mdrMeterReadings: Vector[MdrMeterReading]): Map[GroupingKey, RdasMeterPort] = {
      // Group by MeterPortID so that all readings for the same meter port are lumped together in one
      // RdasMeterPort result structure.
      // MeterPortID in MDR is a foreign key to meterports table's primary key "id", thus it is as well a primary key.
      // As consequence, one RdasMeterPort entry contains one set of information which in theory should be the same
      // for all readings from this meter port, but in practice may not be.
      // In the MeterDataRepository the radioArticleNr, radioSerialNr, and unit are stored in table readings
      // per reading, although they should normally be the same for all readings of a meter port.
      // As the RdasMeterPort does not allow to give these 3 values as part of the reading but only as property of the
      // meter port, one arbitrary reading is chosen from the meter port and its information is taken as reference.
      // The downside is, if the MeterDataRepository would contain different information for different readings of
      // the same meter port, then the different information is lost in the mapping.
      // Actually we see during migration that inconsistent data really exists in the readings table.
      // The alternative approach would group by the 4-tuple meterPortId, radioArticleNr, radioSerialNr, and unit,
      // so that the information describing the meter port in the RdasMeterPort would be consistent.
      // The downside here is that the client would potentially receive several RdasMeterPort structures for
      // the same meter port, thus the fact that inconsistent data exists is made visible.
      // For the moment we do not want to make inconsistencies visible, but rather first log a warning so that we can
      // see how often this happens.
      val rdasMeterPortsMap = mdrMeterReadings.groupBy(groupingKey).map {
        case (meterPortId, readings) =>
          val refReading = readings.head // take any, e.g. the first per group
          val inconsistentReadings = readings.filterNot(r =>
            r.radioArticleNr == refReading.radioArticleNr &&
            r.radioSerialNr == refReading.radioSerialNr &&
            r.unit == refReading.unit)
          if (inconsistentReadings.nonEmpty) {
            // log a warning, but do not throw an exception which would make the Try to return a Failure
            logger.warn("MDR returned readings with inconsistent radioArticleNr, radioSerialNr or unit for the " +
                        s"same meterPortId: refReading: $refReading, inconsistentReadings: $inconsistentReadings")
          }
          val rdasMeterPort = RdasMeterPort(
            refReading.locationId.value,
            refReading.port,
            refReading.mainDeviceId.value,
            refReading.mainArticleNr.value,
            refReading.mainSerialNr.value,
            None, // FIXME Can we obtain the radio component ID somehow here ?
            refReading.radioArticleNr.map(_.value),
            refReading.radioSerialNr.map(_.value),
            refReading.measurand.entryName,
            refReading.unit.entryName,
            readings.map(mapToRdasReading(calibrationCheck))
          )
          (meterPortId, rdasMeterPort)
      }
      rdasMeterPortsMap
    }

    // The following time zone information exists:
    //  - the time zone of the consumption date, which is derived from the time zone of the referenced meter port
    //  - the time zone of the readings request
    // => We use the timezone of the reading as this will match the timezone of the request
    // Later in the RDAS adapter we drop the timezone again to not "confuse" any ista consumers like SAP, jabre or vonovia
    private def mapToRdasReading(calibrationCheck: CalibrationCheck)(reading: MdrMeterReading): RdasReading = {
      val isOutOfCalibrationResult = isOutOfCalibration(calibrationCheck)(reading)

      RdasReading(
        date = reading.consumptionDate.toZonedDateTime(reading.timeZone),
        value = reading.value,
        readingType = mapResponseReadingType(reading.readingType),
        channel = Some(mapResponseChannelType(reading.transportType)),
        medium = mapResponseMediumType(reading.mediumType),
        flags = RdasReadingFlags(isOutOfCalibrationResult) // No estimations yet implemented in MDR
      )
    }

    // Returns true if we know for sure the device is not calibrated anymore at the time of the reading.
    // If we have no knowledge on the last certification date (i.e. reading.certificationDate is None),
    // or the articles service has no knowledge on the article or on the article's certification validity duration
    // (covered within CalibrationCheck), then the device is _not_ considered to be out of calibration,
    // which does not mean it is within calibration but only that we do not know.
    def isOutOfCalibration(calibrationCheck: CalibrationCheck)(reading: MdrMeterReading): Boolean = {
      val maybeIsCalibrated = for {
        lastCertificationDate <- reading.certificationDate
        articleServiceAN = ArticleServiceAN(reading.mainArticleNr.value)
        instantInQuestion = reading.consumptionDate
        isCalibrated <-
          calibrationCheck.isCalibrated(articleServiceAN, lastCertificationDate, instantInQuestion)
      } yield isCalibrated
      maybeIsCalibrated.contains(false)
    }
  }

