  // Implemented according to documentation https://www.postgresql.org/docs/current/ddl-partitioning.html
  // In each run, will only create one partition.
  def createPartitionIfNeeded(tablename: String = "readings", date: => LocalInstant = LocalInstant.nowInGmtPlus1()): () => DBIOAction[Unit, NoStream, Effect] = () => {

    if (date.toLocalDateTime.toLocalTime.getHour > 4) {
      // It is dawning, so we skip the run
      DBIO.successful(())
    } else {
      val datefmt = DateTimeFormatter.ofPattern("uuuu_MM")

      val maybeNextBounds = sql"""
                 select max as lower, max + interval '1 month' as upper
                 from
                   (select max(regexp_replace(pg_get_expr(partition.relpartbound, partition.oid), '.*TO...(.*)..', '\1')::timestamp) as max
                   from pg_class parent, pg_class partition, pg_inherits rel
                   where rel.inhparent = parent.oid and partition.oid = rel.inhrelid
                     and parent.relname = '#$tablename'
                     and pg_get_expr(partition.relpartbound, partition.oid) != 'DEFAULT') as upper_bound
                 where upper_bound.max is not null
                 """.as[(LocalInstant, LocalInstant)].headOption

      maybeNextBounds
        .map {
          case None =>
            // no partitions there -> start at the first of current month
            Some(date.withDayOfMonth(1), LocalInstant(date.toLocalDate.plusMonths(1)).withDayOfMonth(1))
          //noinspection ScalaUnusedSymbol
          case Some((lowerInstant, upperInstant)) if lowerInstant.toLocalDate isAfter date.toLocalDate.plusMonths(3) =>
            // happens when the existing partition max upper bound is more than 1 month in the future
            None
          //noinspection ScalaUnusedSymbol
          case mnb @ Some((lowerInstant, upperInstant)) =>
            // next calculated partition slice
            mnb
        }
        .flatMap {
          case None                               =>

            DBIO.successful(())
          case Some((lowerInstant, upperInstant)) =>
            val lower = lowerInstant.toLocalDate.format(DateTimeFormatter.ISO_LOCAL_DATE)
            val upper = upperInstant.toLocalDate.format(DateTimeFormatter.ISO_LOCAL_DATE)
            val partitionname = tablename + "_p" + lowerInstant.toLocalDate.format(datefmt)

            sql"select create_new_partition('#$tablename', '#$partitionname', '#$lower'::timestamp, '#$upper'::timestamp) is null"
              .as[Boolean]
              .map(_ => ())

        }
    }
  }
