{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/deepseek-v4-pro",
  "small_model": "opencode-go/deepseek-v4-flash",
  "instructions": [
    "CLAUDE.md",
    "CONTRIBUTING.md",
    "docs/guidelines.md"
  ],
  "plugin": [
    "oh-my-openagent@latest",
    "@khalilgharbaoui/opencode-claude-code-plugin"
  ],
  "tools": {
    "bash": false,
    "glob": false,
    "grep": false,
    "list": false,
    "patch": false,
    "skill": false,
    "todoread": false,
    "todowrite": false,
    "webfetch": false,
    "write": false
  },
  "formatter": {
    "scalafmt": {
      "command": [
        "scalafmt",
        "$FILE"
      ],
      "extensions": [
        ".scala",
        ".sc",
        ".sbt"
      ]
    }
  },
  "mcp": {
    "emacs": {
      "type": "remote",
      "url": "http://localhost:8765/mcp",
      "enabled": true
    },
    "ista_jira_confluence": {
      "type": "local",
      "enabled": true,
      "command": [
        "node",
        "{env:HOME}/git/rdm/ai/mcp-jira-confluence/dist/index.js",
        "--jira-url",
        "https://ista.atlassian.net",
        "--confluence-url",
        "https://ista.atlassian.net/wiki",
        "--email",
        "gunnar.bastkowski@ista.com",
        "--token-command",
        "pass show ista/jira-api-token-mcp"
      ]
    },
    "tmux": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "@audibleblink/tmux-mcp-server"
      ]
    },
    "context7": {
      "type": "local",
      "enabled": true,
      "command": [
        "sh",
        "-c",
        "CONTEXT7_API_KEY=\"$(pass show private/context7/api-key)\" exec npx -y @upstash/context7-mcp"
      ]
    }
  },
  "provider": {
    "opencode-go": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenCode Go",
      "options": {
        "baseURL": "https://opencode.ai/zen/go/v1"
      },
      "models": {
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro",
          "tools": true,
          "variants": {
            "none": {},
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        },
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash",
          "tools": true,
          "variants": {
            "none": {},
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        },
        "kimi-k2.6": {
          "name": "Kimi K2.6",
          "tools": true,
          "variants": {
            "none": {},
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        },
        "kimi-k2.5": {
          "name": "Kimi K2.5",
          "tools": true,
          "variants": {
            "none": {},
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        },
        "glm-5.1": {
          "name": "GLM-5.1",
          "tools": true,
          "variants": {
            "none": {},
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        },
        "glm-5": {
          "name": "GLM-5",
          "tools": true,
          "variants": {
            "none": {},
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        },
        "qwen3.6-plus": {
          "name": "Qwen 3.6 Plus",
          "tools": true,
          "variants": {
            "none": {},
            "low": {},
