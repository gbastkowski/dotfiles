  private def findMeterPort(mp: MdrMeterPort): Option[FakeMeterPortInternal] = {
    _meterPorts.values.find(fakeMeterPortInternal =>
      fakeMeterPortInternal.meterPort.execPlanId == mp.execPlanId &&
      fakeMeterPortInternal.meterPort.mainDeviceId == mp.mainDeviceId &&
      fakeMeterPortInternal.meterPort.portNr == mp.portNr
    )
  }

  private def findMeterPort(mpc: MeterPortConfig): Option[FakeMeterPortInternal] = {
    _meterPorts.values.find(mp =>
      mp.meterPort.execPlanId == mpc.execPlanId &&
      mp.meterPort.mainDeviceId == mpc.mainDeviceId &&
      mp.meterPort.portNr == mpc.portNr
    )
  }

  private def upsertMeterPort(mp: MeterPortConfig): Unit = synchronized {
    val internalMpc = domainToSchemaModel(mp)
    findMeterPort(mp).map { oldMp =>
      // found existing meter port configs
      val impc = internalMpc.copy(meterPort = internalMpc.meterPort.copy(id = oldMp.meterPort.id))

      // check whether config with same validity exists
      if (oldMp.configs.exists(_.validFrom == impc.validFrom)) {
        // replace the existing config
        val updatedConfigs = (impc +: oldMp.configs.filter(_.validFrom == impc.validFrom)).sortBy(_.validFrom)
        _meterPorts.put(oldMp.meterPort.id.get, oldMp.copy(meterPort = impc.meterPort, configs = updatedConfigs))
        _properties.put(mp.execPlanId, (mp.propertyId, mp.propertyNumber))
      } else {
        // add the existing config
        val updatedConfigs = (impc +: oldMp.configs).sortBy(_.validFrom)
        _meterPorts.put(oldMp.meterPort.id.get, oldMp.copy(meterPort = impc.meterPort, configs = updatedConfigs))
        _properties.put(mp.execPlanId, (mp.propertyId, mp.propertyNumber))
      }
    }.orElse {
      // no config with this key yet => generate new ID and initialize config list
      val newId = MeterPortID(_meterPortIdCounter.incrementAndGet)
      val impc = internalMpc.copy(meterPort = internalMpc.meterPort.copy(id = Some(newId)))
      _meterPorts.put(newId, FakeMeterPortInternal(impc.meterPort, impc +: Nil))
      _properties.put(mp.execPlanId, (mp.propertyId, mp.propertyNumber))
    }
    ()
  }

  private def upsertMeterPortConfig(mp: MeterPortConfig): Unit = synchronized {
    val internalMpc = domainToSchemaModel(mp)
    findMeterPort(mp).map { oldMp =>
      // found existing meter port configs => set existing meter port in new config
      val impc = internalMpc.copy(meterPort = oldMp.meterPort)
      // check whether config with same validity exists
      if (oldMp.configs.exists(_.validFrom == impc.validFrom)) {
        // replace the existing config
        val updatedConfigs = (impc +: oldMp.configs.filter(_.validFrom == impc.validFrom)).sortBy(_.validFrom)
        _meterPorts.put(oldMp.meterPort.id.get, oldMp.copy(configs = updatedConfigs))
      } else {
        // add the existing config
        val updatedConfigs = (impc +: oldMp.configs).sortBy(_.validFrom)
        _meterPorts.put(oldMp.meterPort.id.get, oldMp.copy(configs = updatedConfigs))
      }
    }.orElse {
      // no config with this key yet => generate new ID and initialize config list
      val newId = MeterPortID(_meterPortIdCounter.incrementAndGet)
      val impc = internalMpc.copy(meterPort = internalMpc.meterPort.copy(id = Some(newId)))
      _meterPorts.put(newId, FakeMeterPortInternal(impc.meterPort, impc +: Nil))
    }
    ()
  }

  override def upsertMeterPorts(mpc: Iterable[MeterPortConfig]): Future[Done] = synchronized {
    logger.debug(s"MDR::upsertMeterPorts: ${mpc.map(mpc => s"[${mpc.execPlanId}:${mpc.mainDeviceId}:${mpc.portNr}-${mpc.articleNr}:${mpc.serialNr}]")}")
    mpc.foreach(upsertMeterPort)
    Future.successful(Done)
  }

