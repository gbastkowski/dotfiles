  private def updateMeterPortDataRetention(mp: MdrMeterPort, dr: CompoundRetentionPolicy): Unit = synchronized {
    findMeterPort(mp).foreach { oldMp =>
      _meterPorts.put(oldMp.meterPort.id.get, oldMp.copy(meterPort = oldMp.meterPort.copy(retentionPolicy = dr)))
    }
  }

  override def updatePropertyDataRetention(propertyId: PropertyID, compoundRetentionPolicy: CompoundRetentionPolicy): Future[Done] = {
